@page
@model dancelog.Pages.CourseDeleteModel
@{
    ViewData["Title"] = "Подтверждение удаления";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-light">
                    <h5 class="mb-0">@ViewData["Title"]</h5>
                </div>
                <div class="card-body text-center">
                    <h5 class="mb-3">Вы уверены, что хотите удалить этот курс?</h5>
                    <p class="text-muted">Это действие нельзя отменить.</p>

                    <div class="d-flex justify-content-center mt-4">
                        <a href="ListOfCourse" class="btn btn-outline-secondary me-3">
                            Отменить
                        </a>
                        <a href="?id=@Request.Query["id"]" class="btn btn-outline-dark">
                            Удалить
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>