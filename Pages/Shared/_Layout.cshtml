<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - dancelog</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/dancelog.styles.css" asp-append-version="true" />
    <link rel="icon" href="https://cdn-icons-png.flaticon.com/512/5969/5969724.png" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        /* Анимация для логотипа */
        .navbar-brand img {
            transition: transform 0.3s ease;
        }

        .navbar-brand:hover img {
            transform: rotate(15deg) scale(1.1);
        }
        /* Стили для навигационных ссылок */
        .nav-link {
            position: relative;
            transition: all 0.3s ease;
            padding-bottom: 5px;
            display: flex;
            align-items: center;
        }

            .nav-link i {
                margin-right: 8px;
                width: 20px;
                text-align: center;
            }

            .nav-link:hover {
                color: #0d6efd !important;
                transform: translateY(-2px);
            }
            /* Отключаем псевдоэлемент подчеркивания */
            .nav-link::after {
                display: none !important;
            }
        /* Отключение стандартного оформления для элементов с классом .no-underline */
        .no-underline {
            text-decoration: none !important;
        }

            .no-underline:hover {
                color: inherit !important;
                transform: none !important;
            }

            .no-underline::after {
                display: none !important;
            }
        /* Универсальные правила для ссылок внутри .navbar-nav */
        .navbar-nav a:focus,
        .navbar-nav a:active {
            outline: none !important;
            box-shadow: none !important;
            background: transparent !important;
            border: none !important;
        }
        /* Эффект увеличения для иконки авторизации */
        .nav-item.dropdown .nav-link i {
            transition: transform 0.3s ease;
        }

        .nav-item.dropdown .nav-link:hover i {
            transform: scale(1.1);
        }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom box-shadow me-3">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-area="" asp-page="/Index">
                    <span class="me-2">DanceLog</span>
                    <img src="https://cdn-icons-png.flaticon.com/512/5969/5969724.png" alt="DanceLog Логотип" width="30" height="30" class="d-inline-block align-text-top">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <!-- Область навигации с выравниванием по правой стороне и вертикальным центрированием -->
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end align-items-center">
                    <!-- Навигационные ссылки -->
                    <ul class="navbar-nav me-3">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/ListOfCourse">
                                <i class="fas fa-book me-1"></i>
                                <span>Курсы</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/ListOfGroups">
                                <i class="fas fa-layer-group me-1"></i>
                                <span>Группы</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/Lesson">
                                <i class="fas fa-calendar-alt me-1"></i>
                                <span>Занятия</span>
                            </a>
                        </li>
                    </ul>
                    <!-- Блок авторизации (выпадающее меню) -->
                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        // Извлекаем только первую часть из User.Identity.Name, если там хранится полное ФИО.
                        var nameParts = (User.Identity.Name ?? "").Split(' ');
                        var firstName = nameParts.Length > 0 ? nameParts[0] : User.Identity.Name;
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link no-underline dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle fa-lg"></i> @firstName
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Profile">Профиль</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Logout">Выход</a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav">
                            <li class="nav-item dropdown">
                                <a class="nav-link no-underline dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle fa-lg"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Login">Войти</a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Register">Регистрация</a>
                                    </li>
                                </ul>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
