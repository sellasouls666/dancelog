<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - dancelog</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/dancelog.styles.css" asp-append-version="true" />
    <link rel="icon" href="https://cdn-icons-png.flaticon.com/512/5969/5969724.png" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />

    <style>
        :root {
            --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        }

        body {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        * {
            transition: background-color 0.3s ease, color 0.3s ease;
        }

        .navbar,
        .nav-link,
        .dropdown-menu,
        .dropdown-item,
        .btn-outline-secondary {
            transition: all 0.3s ease;
        }

        .navbar-brand img {
            transition: transform 0.3s ease;
        }

        .navbar-brand:hover img {
            transform: rotate(15deg) scale(1.1);
        }

        .nav-link {
            position: relative;
            transition: all 0.3s ease;
            padding-bottom: 5px;
            display: flex;
            align-items: center;
            font-weight: normal;
        }

            .nav-link i {
                margin-right: 8px;
                width: 20px;
                text-align: center;
            }

            .nav-link:hover {
                color: #0d6efd !important;
                transform: translateY(-2px);
            }

        .no-underline {
            text-decoration: none !important;
        }

            .no-underline:hover {
                color: inherit !important;
                transform: none !important;
            }

            .no-underline::after {
                display: none !important;
            }

        .navbar-nav a:focus,
        .navbar-nav a:active {
            outline: none !important;
            box-shadow: none !important;
            background: transparent !important;
            border: none !important;
        }

        .nav-item.dropdown .nav-link i {
            transition: transform 0.3s ease;
        }

        .nav-item.dropdown .nav-link:hover i {
            transform: scale(1.1);
        }

        .dropdown-menu {
            border: none;
            box-shadow: 0 5px 15px rgba(0, 0, 0, 0.1);
            border-radius: 10px;
            padding: 0;
            overflow: hidden;
            margin-top: 8px;
            min-width: 180px;
            transform-origin: top right;
            animation: fadeIn 0.15s ease-out;
            font-family: inherit;
        }

        keyframes fadeIn {
            from from:


        {
            opacity: 0;
            transform: translateY(-5px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .dropdown-item {
            padding: 10px 15px;
            transition: all 0.2s ease;
            position: relative;
            color: #333;
            font-weight: normal;
            font-family: inherit;
            font-size: 0.9rem;
        }

            .dropdown-item:first-child {
                border-top-left-radius: 10px;
                border-top-right-radius: 10px;
            }

            .dropdown-item:last-child {
                border-bottom-left-radius: 10px;
                border-bottom-right-radius: 10px;
            }

            .dropdown-item:hover {
                background: var(--primary-gradient);
                color: white !important;
                padding-left: 18px;
            }

            .dropdown-item i {
                margin-right: 10px;
                width: 18px;
                text-align: center;
                color: #6c757d;
                font-size: 0.9rem;
            }

        .dropdown-divider {
            margin: 0;
            border-color: rgba(0, 0, 0, 0.05);
        }

        .user-icon {
            font-size: 1.5rem;
            color: #6c757d;
            transition: all 0.3s ease;
        }

            .user-icon:hover {
                color: #0d6efd;
                transform: scale(1.1);
            }

        .gradient-icon {
            display: inline-block;
            background: var(--primary-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            color: transparent;
        }

        body.dark-theme {
            background-color: #000000;
            color: #e0e0e0;
        }

            body.dark-theme p,
            body.dark-theme li,
            body.dark-theme td,
            body.dark-theme th,
            body.dark-theme input,
            body.dark-theme label,
            body.dark-theme h1,
            body.dark-theme h2,
            body.dark-theme h3,
            body.dark-theme h4,
            body.dark-theme h5,
            body.dark-theme h6 {
                color: #e0e0e0;
            }

            body.dark-theme a:not(.nav-link):not(.dropdown-item) {
                color: #7aa7ff;
            }

            body.dark-theme a:hover {
                color: #a6c8ff;
            }

            body.dark-theme table {
                color: #e0e0e0;
            }

                body.dark-theme table th,
                body.dark-theme table td {
                    border-color: rgba(255, 255, 255, 0.1);
                }

            body.dark-theme input,
            body.dark-theme textarea,
            body.dark-theme select {
                background-color: #000000;
                border: 1px solid #444;
                color: #fff;
            }

                body.dark-theme input::placeholder,
                body.dark-theme textarea::placeholder {
                    color: #aaa;
                }

            body.dark-theme .nav-link i,
            body.dark-theme .dropdown-item i {
                background: var(--primary-gradient);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                color: transparent;
            }

            body.dark-theme #themeToggle i {
                background: none !important;
                -webkit-text-fill-color: initial !important;
                color: #cccccc !important;
            }

            body.dark-theme .logo-img {
                filter: drop-shadow(0 0 2px rgba(240, 240, 240));
            }

            body.dark-theme .user-icon {
                background: var(--primary-gradient);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
                color: transparent;
            }

            body.dark-theme .navbar {
                background-color: #000000 !important;
                border-bottom: 1px solid #000000;
            }

            body.dark-theme .navbar {
                border-bottom: 1px solid #000000 !important;
                box-shadow: none !important;
            }

            body.dark-theme .dropdown-menu {
                background-color: #000000;
            }

            body.dark-theme .dropdown-item {
                color: #ccc;
            }

                body.dark-theme .dropdown-item:hover {
                    background: linear-gradient(135deg, #444 0%, #666 100%);
                    color: black !important;
                }

            body.dark-theme .btn-outline-secondary {
                color: #ccc;
                border-color: #000000;
            }

                body.dark-theme .btn-outline-secondary:hover {
                    background-color: #444;
                    color: #fff;
                }

            body.dark-theme h1,
            body.dark-theme h2,
            body.dark-theme h3,
            body.dark-theme a:not(.nav-link):not(.dropdown-item),
            body.dark-theme .nav-link span,
            body.dark-theme .dropdown-item span {
                background: var(--primary-gradient);
                -webkit-background-clip: text;
                -webkit-text-fill-color: transparent;
            }
    </style>
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-sm navbar-light bg-light border-bottom box-shadow me-3">
            <div class="container">
                <a class="navbar-brand fw-bold d-flex align-items-center" asp-area="" asp-page="/Index">
                    <span class="me-2">DanceLog</span>
                    <img id="logo" src="https://cdn-icons-png.flaticon.com/512/5969/5969724.png"
                         alt="DanceLog Логотип" width="30" height="30" class="d-inline-block align-text-top logo-img">
                </a>
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse"
                        aria-controls="navbarSupportedContent" aria-expanded="false" aria-label="Toggle navigation">
                    <span class="navbar-toggler-icon"></span>
                </button>
                <div class="navbar-collapse collapse d-sm-inline-flex justify-content-end align-items-center">
                    <ul class="navbar-nav me-3">
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/ListOfCourse">
                                <i class="fas fa-book me-1"></i>
                                <span>Курсы</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/ListOfGroups">
                                <i class="fas fa-layer-group me-1"></i>
                                <span>Группы</span>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link text-dark" asp-area="" asp-page="/ListOfLessons">
                                <i class="fas fa-calendar-alt me-1"></i>
                                <span>Занятия</span>
                            </a>
                        </li>
                    </ul>

                    @if (User.Identity?.IsAuthenticated ?? false)
                    {
                        var nameParts = (User.Identity.Name ?? "").Split(' ');
                        var firstName = nameParts.Length > 0 ? nameParts[0] : User.Identity.Name;
                        <ul class="navbar-nav align-items-center">
                            <li class="nav-item dropdown">
                                <a class="nav-link no-underline dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle user-icon"></i>
                                    <span class="ms-2">@firstName</span>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Profile">
                                            <i class="fas fa-user"></i> Профиль
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Админ"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-page="/Account/ListOfUsers">
                                                <i class="fas fa-server"></i> Пользователи
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Logout">
                                            <i class="fas fa-sign-out-alt"></i> Выход
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <button id="themeToggle" class="btn btn-sm btn-outline-secondary ms-2" title="Сменить тему">
                                    <i class="fas fa-moon"></i>
                                </button>
                            </li>
                        </ul>
                    }
                    else
                    {
                        <ul class="navbar-nav align-items-center">
                            <li class="nav-item dropdown">
                                <a class="nav-link no-underline dropdown-toggle" href="#" id="userDropdown" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    <i class="fas fa-user-circle user-icon"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userDropdown">
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Login">
                                            <i class="fas fa-sign-in-alt"></i> Войти
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-page="/Account/Register">
                                            <i class="fas fa-user-plus"></i> Регистрация
                                        </a>
                                    </li>
                                </ul>
                            </li>
                            <li class="nav-item">
                                <button id="themeToggle" class="btn btn-sm btn-outline-secondary ms-2" title="Сменить тему">
                                    <i class="fas fa-moon"></i>
                                </button>
                            </li>
                        </ul>
                    }
                </div>
            </div>
        </nav>
    </header>

    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- 🎵 Sound effect -->
    <audio id="themeSound" src="https://cdn.pixabay.com/download/audio/2022/03/15/audio_7b8f5e4b35.mp3?filename=switch-click-106763.mp3" preload="auto"></audio>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>



    <script>
        const toggleBtn = document.getElementById('themeToggle');
        const icon = toggleBtn.querySelector('i');
        const logo = document.getElementById('logo');
        const themeSound = document.getElementById('themeSound');
        const userIcons = document.querySelectorAll('.user-icon');

        function applyTheme(theme) {
            const isDark = theme === 'dark';
            document.body.classList.toggle('dark-theme', isDark);
            icon.classList.toggle('fa-sun', isDark);
            icon.classList.toggle('fa-moon', !isDark);

            if (isDark) {
                logo.classList.add('gradient-icon');
                userIcons.forEach(icon => icon.classList.add('gradient-icon'));
            } else {
                logo.classList.remove('gradient-icon');
                userIcons.forEach(icon => icon.classList.remove('gradient-icon'));
            }

            localStorage.setItem('theme', theme);
        }

        const systemPrefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        const savedTheme = localStorage.getItem('theme') || (systemPrefersDark ? 'dark' : 'light');
        applyTheme(savedTheme);

        toggleBtn.addEventListener('click', () => {
            themeSound.currentTime = 0;
            themeSound.play();

            const newTheme = document.body.classList.contains('dark-theme') ? 'light' : 'dark';
            applyTheme(newTheme);
        });
    </script>


    <script>
        const toggleBtn = document.getElementById('themeToggle');
        const icon = toggleBtn.querySelector('i');
        const logo = document.getElementById('logo');
        const themeSound = document.getElementById('themeSound');
        const userIcons = document.querySelectorAll('.user-icon');

        function applyTheme(theme) {
            const isDark = theme === 'dark';
            document.body.classList.toggle('dark-theme', isDark);
            icon.classList.toggle('fa-sun', isDark);
            icon.classList.toggle('fa-moon', !isDark);

            if (isDark) {
                logo.classList.add('gradient-icon');
                userIcons.forEach(icon => icon.classList.add('gradient-icon'));
            } else {
                logo.classList.remove('gradient-icon');
                userIcons.forEach(icon => icon.classList.remove('gradient-icon'));
            }

            localStorage.setItem('theme', theme);
        }

        const systemPrefersDark = window.matchMedia && window.matchMedia('(prefers-color-scheme: dark)').matches;
        const savedTheme = localStorage.getItem('theme') || (systemPrefersDark ? 'dark' : 'light');
        applyTheme(savedTheme);

        toggleBtn.addEventListener('click', () => {
            toggleBtn.classList.add('clicked', 'glow');
            themeSound.currentTime = 0;
            themeSound.play();

            setTimeout(() => {
                toggleBtn.classList.remove('clicked', 'glow');
            }, 400);

            const newTheme = document.body.classList.contains('dark-theme') ? 'light' : 'dark';
            applyTheme(newTheme);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
    <audio id="themeSound" src="~/sounds/theme-switch.mp3" preload="auto"></audio>
</body>
</html>
