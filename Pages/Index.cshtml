@page
@model IndexModel
@{
    ViewData["Title"] = "Журнал посещаемости студента";
}

<style>
    /* Анимации кнопок в едином стиле */
    .btn-main-action {
        transition: all 0.2s ease;
        border-width: 1px;
    }

        .btn-main-action:hover {
            transform: translateY(-2px);
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
        }

    /* Анимация заголовка */
    .welcome-title {
        animation: fadeInUp 0.6s ease-out;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }
</style>

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-8 text-center">
            <div class="welcome-title">
                <h1 class="display-4 fw-bold mb-4">Добро пожаловать в DanceLog</h1>
                <h2 class="display-6 fw-normal text-muted mb-4">Журнал посещаемости</h2>
                <p class="fs-5 text-muted mb-5">Здесь вы можете вести учет посещаемости студентов.</p>
            </div>

            <div class="d-flex justify-content-center gap-3">
                <a href="/ListOfAttendance" class="btn btn-outline-dark btn-main-action px-4 py-2">
                    <i class="fas fa-clipboard-list me-2"></i>Посещаемость
                </a>
                <a href="/ListOfStudents" class="btn btn-outline-dark btn-main-action px-4 py-2">
                    <i class="fas fa-users me-2"></i>Студенты
                </a>
            </div>
        </div>
    </div>
</div>