@page
@model dancelog.Pages.CourseModel
@{
    ViewData["Title"] = Model.Course.Id == 0 ? "Добавить курс" : "Редактировать курс";
}

<style>
    :root {
        /* === Основные цвета (светлая тема) === */
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --border-color: #e0e0e0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
        --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
        --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        --bg-page: linear-gradient(to bottom, #f5f7fa 0%, #e4e8eb 100%);
        --card-bg: #ffffff;
        --form-bg: #f0f0f0; /* фон полей в светлой теме */
        --form-bg-hover: #eaeaea;
        --form-bg-focus: #ffffff;
        --text-color: #212529;
        --header-bg: var(--primary-gradient);
    }

    body {
        background: var(--bg-page);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
    }

        /* === Тёмная тема === */
        body.dark-theme {
            --bg-page: #000000;
            --card-bg: #121212;
            --border-color: #444444;
            --text-muted: #a0a0a0;
            --text-color: #f1f1f1;
            --form-bg: #121212;
            --form-bg-hover: #4a4a4a;
            --form-bg-focus: #4a4a4a;
            --header-bg: var(--primary-gradient);
            background: var(--bg-page) !important;
        }


    /* Карточка */
    .card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        background: var(--card-bg);
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }

    .card-header {
        background: var(--header-bg);
        color: #fff;
    }

    /* Поля */
    .form-label {
        font-weight: 500;
        color: var(--text-color);
    }

    .form-control {
        background-color: var(--form-bg) !important;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 10px 15px;
        color: var(--text-color) !important;
        transition: var(--transition);
    }

        .form-control:hover {
            background-color: var(--form-bg-hover) !important;
            border-color: var(--primary-light) !important;
            box-shadow: var(--shadow-sm) !important;
        }

        .form-control:focus {
            background-color: var(--form-bg-focus) !important;
            border-color: var(--primary-light) !important;
            box-shadow: 0 0 0 0.25rem rgba(37,117,252,0.25) !important;
            outline: none;
            color: var(--text-color) !important;
        }

    body.dark-theme .form-control::placeholder {
        color: #bbb !important;
        opacity: 1;
    }

    /* Кнопки */
    .btn-outline-dark {
        border-radius: 8px;
        padding: 8px 20px;
        border-color: var(--primary-dark);
        color: var(--primary-dark);
        transition: var(--transition);
    }

        .btn-outline-dark:hover {
            background: var(--primary-gradient);
            border-color: var(--primary-gradient);
            color: #fff;
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm);
        }

    .btn-outline-secondary {
        border-radius: 8px;
        padding: 8px 20px;
        border-color: var(--text-muted);
        color: var(--text-muted);
        transition: var(--transition);
    }

        .btn-outline-secondary:hover {
            background: var(--light-gray);
            color: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm);
        }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card">
                <div class="card-header">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Course.Id" />

                        <div class="mb-3">
                            <label asp-for="Course.Name" class="form-label">Название курса</label>
                            <input asp-for="Course.Name" class="form-control" required />
                            <span asp-validation-for="Course.Name" class="text-danger small"></span>
                        </div>

                        <div class="d-flex justify-content-end mt-4">
                            <a href="ListOfCourse" class="btn btn-outline-secondary me-2">Отмена</a>
                            <button type="submit" class="btn btn-outline-dark">
                                @(Model.Course.Id == 0 ? "Добавить" : "Сохранить")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
