@page "{id:int}"
@model dancelog.Pages.StudentModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Добавить студента" : "Редактировать студента";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --bg-page: #ffffff;
        --bg-card: #ffffff;
        --bg-input: #ffffff;
        --text-color: #212529; /* основной текст */
        --text-muted: #6c757d; /* подсказки и метки */
        --border-color: #ced4da; /* рамки */
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.6);
        --shadow-lg: 0 4px 12px rgba(0,0,0,0.7);
        --transition: all 0.2s ease;

    }

    body.dark-theme {
        --bg-page: #18191a;
        --bg-card: #242526;
        --bg-input: #2e2e2e;
        --text-color: #e4e6eb;
        --text-muted: #8a8c8e;
        --border-color: #3a3b3c;
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.6);
        --shadow-lg: 0 4px 12px rgba(0,0,0,0.7);
    }
    /* ========== 1) в светлой теме чуть затемнённый фон инпутов ========== */
    body:not(.dark-theme) .form-control:not([readonly]) {
        background: #f2f2f2 !important; /* чуть серее, чтобы текст не сливался */
        color: var(--text-color) !important; /* тёмный текст из переменной */
    }

    /* ========== 2) в светлой теме кнопка «Отмена» тёмная и с рамкой ========== */
    body:not(.dark-theme) .btn-cancel,
    body:not(.dark-theme) a.btn-cancel {
        background: transparent !important;
        color: var(--text-color) !important; /* тёмный текст */
        border: 1px solid var(--border-color) !important; /* тёмная рамка */
    }

    body {
        background: var(--bg-page);
        color: var(--text-color);
    }

    .card {
        background: var(--bg-card);
        border-radius: 12px;
        box-shadow: var(--shadow-sm);
        border: none;
        overflow: hidden;
    }

    .card-header {
        background: var(--primary-gradient);
        color: #fff;
        border-top-left-radius: 12px;
        border-top-right-radius: 12px;
    }

    .form-control {
        color: var(--text-color);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: .75rem 1rem;
        height: 48px;
        transition: var(--transition);
        background: var(--bg-input);
        color: var(--text-color);
    }

        /* серый фон для редактируемых полей */
        .form-control:not([readonly]) {
            background: var(--bg-input);
            color: #fff;
        }

        /* светлый фон у readonly (Email) */
        .form-control[readonly] {
            background: var(--bg-input); /* тёмно-серый фон, как у остальных */
             color: var(--text-muted);
            
        }

        .form-control::placeholder {
            color: var(--text-muted);
        }

        .form-control:focus {
            background: var(--bg-input);
            border-color: #3498db;
            box-shadow: 0 0 0 2px rgba(52,152,219,0.3);
            outline: none;
        }

    /* кнопка «Отмена» */
    .btn-cancel {
        background: var(--bg-card); /* или оставьте свой фон */
        color: #fff; /* белый текст */
        border: 1px solid #fff; /* белая обводка */
        border-radius: 8px;
        padding: .75rem 1.5rem;
        transition: background .2s ease;
    }

        .btn-cancel:hover {
            background: rgba(255,255,255,0.1); /* лёгкий подсвет на чёрном фоне */
        }

    /* градиентная кнопка «Сохранить» */
    .btn-gradient {
        background: var(--primary-gradient) !important;
        color: #fff !important;
        border: none;
        border-radius: 8px;
        padding: .75rem 1.5rem;
        font-weight: 600;
        transition: transform .2s ease, box-shadow .2s ease, filter .2s ease;
    }
    

        .btn-gradient:hover {
        ttransform: translateY(-2px);
        box-shadow: var(--shadow-lg);
        filter: brightness(1.1);
    }
        

    /* выбор группы */
    .btn-group-select {
        background: var(--bg-card);
        color: var(--text-color);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 1rem;
        transition: var(--transition);
    }

        .btn-group-select:hover {
            background: var(--bg-input);
        }

    .btn-check:checked + .btn-group-select {
        background: var(--primary-gradient);
        color: #fff;
        border-color: var(--primary-gradient);
    }

    /* выравнивание кнопок вправо */
    .action-buttons {
        display: flex;
        justify-content: flex-end;
        gap: .75rem;
        margin-top: 1.5rem;
    }

    .btn-cancel {
        background: transparent;
        color: #fff; /* белый текст по умолчанию */
        border: 1px solid #fff;
        border-radius: 8px;
        padding: .75rem 1.5rem;
        text-decoration: none; /* убираем подчерк */
        transition: background .2s ease, color .2s ease;
    }

        .btn-cancel:hover,
        .btn-cancel:focus {
            background: rgba(255,255,255,0.1); /* лёгкая белая заливка при наведении */
            color: #fff; /* текст остаётся белым */
        }
    /* перебиваем все состояния ссылки */
    a.btn-cancel,
    a.btn-cancel:link,
    a.btn-cancel:visited,
    a.btn-cancel:hover,
    a.btn-cancel:focus,
    a.btn-cancel:active {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: .75rem 1.5rem;
        border: 1px solid #fff !important;
        border-radius: 8px;
        background: transparent !important;
        color: #fff !important; /* белый текст во всех состояниях */
        text-decoration: none !important; /* убираем подчёркивание */
        transition: background .2s ease;
    }

        /* только hover/focus дают заливку */
        a.btn-cancel:hover,
        a.btn-cancel:focus {
            background: rgba(255,255,255,0.1) !important;
        }
    /* вместо градиента делаем сплошной фиолетовый фон и белый текст */
    .btn-check:checked + .btn-group-select {
        background: var(--bg-card) !important; /* тот же фон, что и у остальных */
        border-color: #8e44ad !important; /* ярко-фиолетовая рамка */
        color: #8e44ad !important; /* икона и текст фиолетовые */
    }
    /* Чтобы внутри .btn-group-select иконка брала цвет родителя */
    .btn-group-select i {
        color: inherit;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card">
                <div class="card-header p-4">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="Student.Id" />

                        <!-- 1) Email -->
                        <div class="mb-email mb-4">
                            <label asp-for="Student.Email" class="form-label">
                                <i class="fas fa-lock me-1"></i>Email
                            </label>
                            <input asp-for="Student.Email"
                                   class="form-control"
                                   readonly />
                            <span asp-validation-for="Student.Email" class="text-danger small"></span>
                        </div>

                        <!-- 2) Фамилия/Имя/Отчество в ряд -->
                        <div class="row row-cols-3 g-3 mb-4">
                            <div class="col">
                                <label asp-for="Student.Surname" class="form-label">Фамилия</label>
                                <input asp-for="Student.Surname"
                                       class="form-control"
                                       placeholder="Фамилия" required />
                                <span asp-validation-for="Student.Surname" class="text-danger small"></span>
                            </div>
                            <div class="col">
                                <label asp-for="Student.Name" class="form-label">Имя</label>
                                <input asp-for="Student.Name"
                                       class="form-control"
                                       placeholder="Имя" required />
                                <span asp-validation-for="Student.Name" class="text-danger small"></span>
                            </div>
                            <div class="col">
                                <label asp-for="Student.Patronymic" class="form-label">Отчество</label>
                                <input asp-for="Student.Patronymic"
                                       class="form-control"
                                       placeholder="Отчество" />
                            </div>
                        </div>

                        <!-- 3) Выбор группы -->
                        <div class="mb-4">
                            <label class="form-label">Группа</label>
                            <div class="group-selection">
                                @foreach (var grp in Model.Groups)
                                {
                                    <input type="radio"
                                           asp-for="Student.GroupId"
                                           id="grp_@grp.Value"
                                           name="Student.GroupId"
                                           value="@grp.Value"
                                           class="btn-check" />
                                    <label for="grp_@grp.Value" class="btn-group-select">
                                        @grp.Text
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Student.GroupId" class="text-danger small"></span>
                        </div>

                        <!-- 4) Кнопки выровнены вправо -->
                        <div class="action-buttons">
                            <a href="…" class="btn-cancel">Отмена</a>
                            <button type="submit" class="btn-gradient">
                                <i class="fas fa-save me-1"></i>
                                @(Model.Id == 0 ? "Добавить" : "Сохранить")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
