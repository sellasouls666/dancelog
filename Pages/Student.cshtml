@page "{id:int}"
@model dancelog.Pages.StudentModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Добавить студента" : "Редактировать студента";
}

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h2 class="card-title mb-4">@ViewData["Title"]</h2>

                    <form method="post">
                        <input type="hidden" asp-for="Student.Id" />

                        <div class="row mb-3">
                            <div class="col-md-4">
                                <label asp-for="Student.Surname" class="form-label">Фамилия*</label>
                                <input asp-for="Student.Surname" class="form-control" />
                                <span asp-validation-for="Student.Surname" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Student.Name" class="form-label">Имя*</label>
                                <input asp-for="Student.Name" class="form-control" />
                                <span asp-validation-for="Student.Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-4">
                                <label asp-for="Student.Patronymic" class="form-label">Отчество</label>
                                <input asp-for="Student.Patronymic" class="form-control" />
                            </div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Student.GroupId" class="form-label">Группа*</label>
                            <select asp-for="Student.GroupId" class="form-select"
                                    asp-items="Model.Groups">
                                <option value="">Выберите группу</option>
                            </select>
                            <span asp-validation-for="Student.GroupId" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Student.Email" class="form-label">Email</label>
                            <input asp-for="Student.Email" class="form-control" type="email" />
                            <span asp-validation-for="Student.Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Student.PhoneNumber" class="form-label">Номер телефона*</label>
                            <input asp-for="Student.PhoneNumber" class="form-control" placeholder="79998887766" />
                            <span asp-validation-for="Student.PhoneNumber" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between mt-4">
                            <a href="@Url.Page("ListOfStudents")" class="btn btn-outline-secondary">
                                Назад к списку
                            </a>
                            <button type="submit" class="btn btn-dark">
                                Сохранить
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}