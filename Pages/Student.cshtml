@page "{id:int}"
@model dancelog.Pages.StudentModel
@{
    ViewData["Title"] = Model.Id == 0 ? "Добавить студента" : "Редактировать студента";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --text-muted: #6c757d;
        --border-color: #e0e0e0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
        --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    body {
        background: linear-gradient(to bottom, #f5f7fa 0%, #e4e8eb 100%);
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        min-height: 100vh;
    }

    .card {
        border: none;
        border-radius: 12px;
        box-shadow: var(--shadow-sm);
        transition: transform 0.2s ease, box-shadow 0.2s ease;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-lg);
        }

    .card-header {
        background: var(--primary-gradient);
        color: #fff;
        padding: 1rem 1.5rem;
    }

    .form-label {
        font-weight: 500;
        color: #343a40;
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control {
        width: 100%;
        padding: 10px 15px;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        background: #f0f0f0;
        transition: var(--transition);
    }

        .form-control:hover,
        .form-control:focus {
            background: #fff;
            box-shadow: var(--shadow-sm);
            border-color: #2575fc;
            outline: none;
        }

    /* Новая секция выбора группы */
    .group-selection {
        display: flex;
        flex-wrap: wrap;
        gap: 0.5rem;
        margin-top: 0.5rem;
    }

    .btn-check {
        display: none;
    }

    .btn-group-select {
        padding: 0.5rem 1rem;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        cursor: pointer;
        transition: var(--transition);
        background: #f0f0f0;
        user-select: none;
    }

        .btn-group-select:hover {
            background: #fff;
            box-shadow: var(--shadow-sm);
            border-color: #bdbdbd;
        }

    .btn-check:checked + .btn-group-select {
        background: var(--primary-gradient);
        color: #fff;
        border-color: var(--primary-gradient);
    }

    .readonly-section {
        margin-top: 1.5rem;
        padding: 1rem;
        background: #f8f9fa;
        border: 1px solid var(--border-color);
        border-radius: 8px;
    }

    .profile-field-readonly {
        background: #e4e8eb;
        cursor: not-allowed;
        opacity: 0.8;
    }

    .action-buttons {
        margin-top: 2rem;
        display: flex;
        justify-content: flex-end;
        gap: 0.5rem;
    }

    .btn-outline-secondary,
    .btn-outline-dark {
        border-radius: 8px;
        padding: 8px 20px;
        transition: var(--transition);
    }

    .btn-outline-secondary {
        border-color: var(--text-muted);
        color: var(--text-muted);
    }

        .btn-outline-secondary:hover {
            background: #f0f0f0;
            color: #343a40;
            box-shadow: var(--shadow-sm);
        }

    .btn-outline-dark {
        border-color: #343a40;
        color: #343a40;
    }

        .btn-outline-dark:hover {
            background: #343a40;
            color: #fff;
            box-shadow: var(--shadow-sm);
        }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body p-4">
                    <form method="post">
                        <input type="hidden" asp-for="Student.Id" />

                        <div class="mb-3">
                            <label asp-for="Student.Surname" class="form-label">Фамилия</label>
                            <input asp-for="Student.Surname" class="form-control" required />
                            <span asp-validation-for="Student.Surname" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Student.Name" class="form-label">Имя</label>
                            <input asp-for="Student.Name" class="form-control" required />
                            <span asp-validation-for="Student.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Student.Patronymic" class="form-label">Отчество</label>
                            <input asp-for="Student.Patronymic" class="form-control" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Группа</label>
                            <div class="group-selection">
                                @foreach (var grp in Model.Groups)
                                {
                                    <input type="radio"
                                           asp-for="Student.GroupId"
                                           id="grp_@grp.Value"
                                           name="Student.GroupId"
                                           value="@grp.Value"
                                           class="btn-check" />
                                    <label for="grp_@grp.Value" class="btn-group-select">
                                        @grp.Text
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Student.GroupId" class="text-danger small"></span>
                        </div>

                        <div class="readonly-section">
                            <label asp-for="Student.Email" class="form-label">
                                <i class="fas fa-lock"></i> Email
                            </label>
                            <input asp-for="Student.Email"
                                   class="form-control profile-field-readonly"
                                   readonly />
                            <span asp-validation-for="Student.Email" class="text-danger small"></span>
                        </div>

                        <div class="action-buttons">
                            <a href="@Url.Page("ListOfStudents")" class="btn btn-outline-secondary">Отмена</a>
                            <button type="submit" class="btn btn-outline-dark">
                                @(Model.Id == 0 ? "Добавить" : "Сохранить")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
