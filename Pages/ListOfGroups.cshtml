@page
@model dancelog.Pages.ListOfGroupsModel
@{
    ViewData["Title"] = "Список групп";
}

<style>
    /* Анимации для карточек в стиле страницы курсов */
    .card {
        transition: transform 0.2s ease-in-out;
    }

        .card:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

    /* Анимация кнопок (сохраняем ваши стили) */
    .btn-group-action {
        transition: all 0.2s ease;
    }

        .btn-group-action:hover {
            transform: scale(1.05);
        }
</style>

<div class="container py-4">
    @if (Model.Groups != null && Model.Groups.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">@ViewData["Title"]</h1>
            <a href="@Url.Page("Group", new { id = 0 })" class="btn btn-outline-dark">
                <i class="fas fa-plus me-1"></i> Создать группу
            </a>
        </div>

        <div class="row g-4">
            @foreach (var group in Model.Groups)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">@group.Name</h5>
                            <p class="card-text text-muted small">
                                <i class="fas fa-book-open me-1"></i> @(group.Course?.Name ?? "Курс не указан")
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-flex justify-content-end">
                                <a href="@Url.Page("Group", new { id = group.Id })"
                                   class="btn btn-sm btn-outline-secondary me-2 btn-group-action">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="javascript:void(0);"
                                   onclick="confirmDelete(@group.Id)"
                                   class="btn btn-sm btn-outline-secondary btn-group-action">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="card shadow-sm">
                <div class="card-body py-5">
                    <h4 class="mt-3">Нет добавленных групп</h4>
                    <p class="text-muted">Нажмите кнопку ниже, чтобы создать группу</p>
                    <a href="@Url.Page("Group", new { id = 0 })" class="btn btn-outline-dark mt-3">
                        <i class="fas fa-plus me-1"></i> Создать новую группу
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить эту группу?')) {
                window.location.href = '@Url.Page("GroupDelete")' + '?id=' + id;
            }
        }
    </script>
}