@page
@model dancelog.Pages.ListOfGroupsModel
@{
    ViewData["Title"] = "Список групп";
}

<h1>Список групп</h1>
@if (Model.Groups != null && Model.Groups.Any())
{
    <table class="table">
        <thead>
            <tr>
                <th>Название группы</th>
                <th>Название курса</th>
                <th>Действия</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var group in Model.Groups)
            {
                <tr>
                    <td>@group.Name</td>
                    <td>@(group.Course?.Name ?? "Курс не указан")</td>
                    <td>
                        <a class="btn btn-sm btn-primary" href="@Url.Page("Group", new { id = group.Id })">Редактировать</a>
                        <a href="javascript:void(0);"
                           onclick="confirmDelete(@group.Id)"
                           class="btn btn-sm btn-outline-secondary">
                            Удалить
                        </a>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p>Группы не найдены.</p>
}

<a class="btn btn-primary" href="@Url.Page("Group", new { id = 0 })">Создать новую группу</a>


@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить эту группу?')) {
                window.location.href = '@Url.Page("GroupDelete")' + '?id=' + id;
            }
        }
    </script>
}