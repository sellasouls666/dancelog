@page
@model dancelog.Pages.GroupModel
@{
    ViewData["Title"] = Model.Group.Id == 0 ? "Добавить группу" : "Редактировать группу";
}

<style>
    :root {
        /* === Основные цвета (светлая тема) === */
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --border-color: #e0e0e0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
        --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
        --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        --bg-page: linear-gradient(to bottom, #f5f7fa 0%, #e4e8eb 100%);
        --card-bg: #ffffff;
        --table-bg: #ffffff;
        --lighter-gray: #f0f0f0;
        --form-bg: #f0f0f0; /* фон полей в светлой теме */
        --form-bg-hover: #eaeaea;
        --form-bg-focus: #ffffff;
        --text-color: #212529;
    }

    body {
        background: var(--bg-page);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
    }

        /* === Тёмная тема === */
        body.dark-theme {
            --bg-page: #000000;
            --card-bg: #2a2a2a;
            --table-bg: #3a3a3a;
            --lighter-gray: #2a2a2a;
            --form-bg: #3a3a3a;
            --form-bg-hover: #4a4a4a;
            --form-bg-focus: #4a4a4a;
            --border-color: #444444;
            --text-muted: #a0a0a0;
            --text-color: #f1f1f1;
            --form-bg: #3a3a3a; /* фон по умолчанию */
            --form-bg-hover: #4a4a4a; /* при наведении */
            --form-bg-focus: #4a4a4a; /* при фокусе */
        }

    /* Карточки */
    .card {
        border: none;
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        background: var(--card-bg);body.dark-theme .form-control
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .card:hover {
            transform: translateY(-3px);
            box-shadow: var(--shadow-md);
        }

    .card-header {
        background: var(--primary-gradient);
        color: #fff;
    }

    /* Формы */
    .form-label {
        font-weight: 500;
        color: var(--text-color);
        display: block;
        margin-bottom: 0.5rem;
    }

    .form-control {
        background-color: var(--form-bg);
        border: 1px solid var(--border-color);
        border-radius: 8px;
        padding: 10px 15px;
        color: var(--text-color);
        transition: var(--transition);
    }

    body.dark-theme .form-control {
        background-color: var(--form-bg) !important;
        color: var(--text-color) !important;
    }

        .form-control:hover {
        background-color: var(--form-bg-hover) !important;
            border-color: var(--primary-light);
            box-shadow: var(--shadow-sm);
        }

        .form-control:focus {
        background-color: var(--form-bg-hover) !important;
            border-color: var(--primary-light);
            box-shadow: 0 0 0 0.25rem rgba(37,117,252,0.25);
            outline: none;
        }

    body.dark-theme .form-control::placeholder {
        color: #bbb;
        opacity: 1;
    }

    

    /* Кнопки */
    .btn-outline-dark {
        border-radius: 8px;
        padding: 8px 20px;
        border-color: var(--primary-dark);
        color: var(--primary-dark);
        transition: var(--transition);
    }

        .btn-outline-dark:hover {
            background: var(--primary-gradient);
            border-color: var(--primary-gradient);
            color: #fff;
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm);
        }

    .btn-outline-secondary {
        border-radius: 8px;
        padding: 8px 20px;
        border-color: var(--text-muted);
        color: var(--text-muted);
        transition: var(--transition);
    }

        .btn-outline-secondary:hover {
            background: var(--light-gray);
            color: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm);
        }

    /* Course selector */
    .course-selector {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
    }

    .course-option {
        flex: 1 0 calc(50% - 10px);
        position: relative;
    }

        .course-option input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .course-option label {
            display: block;
            padding: 12px 15px;
            border: 2px solid var(--border-color);
            border-radius: 8px;
            background-color: var(--card-bg);
            cursor: pointer;
            transition: var(--transition);
            text-align: center;
            font-weight: 500;
            color: var(--text-color);
        }

            .course-option label:hover {
                border-color: var(--primary-light);
                transform: translateY(-2px);
                box-shadow: var(--shadow-sm);
            }

        .course-option input[type="radio"]:checked + label {
            border-color: var(--primary-dark);
            background: linear-gradient(135deg, rgba(106,17,203,0.1) 0%, rgba(37,117,252,0.1) 100%);
            color: var(--primary-dark);
        }

    /* Таблицы */
    table,
    .table {
        width: 100%;
        background-color: var(--table-bg);
        color: var(--text-color);
        border-collapse: collapse;
    }

        .table th,
        .table td {
            padding: 0.75rem;
            border: 1px solid var(--border-color);
            background-color: var(--table-bg);
        }

    .d-flex-end {
        display: flex;
        justify-content: flex-end;
    }
</style>

<div class="container py-4">
    <div class="row justify-content-center">
        <div class="col-lg-6">
            <div class="card shadow-sm">
                <div class="card-header">
                    <h4 class="mb-0">@ViewData["Title"]</h4>
                </div>
                <div class="card-body">
                    <form method="post">
                        <input type="hidden" asp-for="Group.Id" />

                        <div class="mb-3">
                            <label asp-for="Group.Name" class="form-label">Название группы</label>
                            <input asp-for="Group.Name" class="form-control" required />
                            <span asp-validation-for="Group.Name" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Курс</label>
                            <div class="course-selector">
                                @foreach (var opt in Model.CourseOptions)
                                {
                                    <div class="course-option">
                                        <input type="radio"
                                               asp-for="Group.CourseId"
                                               id="course_@opt.Value"
                                               value="@opt.Value" />
                                        <label for="course_@opt.Value">@opt.Text</label>
                                    </div>
                                }
                            </div>
                            <span asp-validation-for="Group.CourseId" class="text-danger small"></span>
                        </div>

                        <div class="d-flex-end mt-4">
                            <a href="ListOfGroups" class="btn btn-outline-secondary me-2">Отмена</a>
                            <button type="submit" class="btn btn-outline-dark">
                                @(Model.Group.Id == 0 ? "Добавить" : "Сохранить")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}