@page
@model dancelog.Pages.Account.EditProfileModel
@using dancelog.Models.Auth
@{
    ViewData["Title"] = "Редактирование профиля";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --light-gray: #f8f9fa;
        --lighter-gray: #f0f0f0;
        --border-color: #e0e0e0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
        --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
        --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
    }

    .profile-container {
        max-width: 520px;
        margin: 2rem auto;
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .profile-card {
        border: none;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        background: white;
        position: relative;
    }

    .form-group {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-muted);
        font-weight: 500;
        text-align: left;
    }

    .profile-field {
        border: 1px solid var(--border-color);
        border-radius: 10px;
        padding: 12px 16px;
        background-color: white;
        transition: var(--transition);
        width: 100%;
        font-size: 0.95rem;
    }

        .profile-field:hover {
            border-color: #bdbdbd;
            box-shadow: var(--shadow-sm);
        }

        .profile-field:focus {
            border-color: var(--primary-light);
            box-shadow: 0 0 0 3px rgba(37, 117, 252, 0.2);
            outline: none;
        }

    .readonly-section {
        background-color: var(--light-gray);
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 1.5rem;
        border: 1px solid var(--border-color);
    }

    .readonly-section-title {
        font-size: 1.5rem;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
        text-align: center;
    }

    .profile-field-readonly {
        background-color: var(--lighter-gray);
        cursor: not-allowed;
        opacity: 0.9;
    }

    .action-buttons {
        display: flex;
        justify-content: space-between;
        margin-top: 2rem;
        gap: 1rem;
    }

    .btn {
        border-radius: 10px;
        padding: 10px 24px;
        font-weight: 500;
        transition: var(--transition);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
    }

    .btn-primary {
        background: var(--primary-gradient);
        border: none;
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .btn-outline {
        border: 1px solid var(--border-color);
        background: white;
        color: var(--text-muted);
    }

        .btn-outline:hover {
            background: var(--light-gray);
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm);
        }

    .btn i {
        margin-right: 8px;
        font-size: 0.9em;
    }

    .profile-title {
        text-align: center;
        margin-bottom: 2rem;
        position: relative;
        padding-bottom: 1rem;
    }

        .profile-title::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: var(--primary-gradient);
            border-radius: 2px;
        }

    .text-danger {
        font-size: 0.8rem;
        margin-top: 0.5rem;
        color: #dc3545;
        display: block;
        text-align: left;
    }
</style>

<div class="container py-4">
    <div class="profile-container">
        <div class="profile-card">
            <div class="card-body p-4 p-lg-5">
                <h2 class="profile-title">@ViewData["Title"]</h2>

                <form method="post" class="needs-validation" novalidate>
                    <div class="form-group">
                        <label asp-for="Input.FirstName" class="form-label">Имя</label>
                        <input asp-for="Input.FirstName" class="profile-field" required />
                        <span asp-validation-for="Input.FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.LastName" class="form-label">Фамилия</label>
                        <input asp-for="Input.LastName" class="profile-field" />
                        <span asp-validation-for="Input.LastName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="Input.MiddleName" class="form-label">Отчество</label>
                        <input asp-for="Input.MiddleName" class="profile-field" />
                        <span asp-validation-for="Input.MiddleName" class="text-danger"></span>
                    </div>

                    <div class="readonly-section">
                        <div class="readonly-section-title">
                            <i class="fas fa-lock"></i>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input asp-for="Input.Email" class="profile-field profile-field-readonly" readonly />
                            <span asp-validation-for="Input.Email" class="text-danger"></span>
                        </div>

                        <div class="form-group mb-0">
                            <label class="form-label">Роль</label>
                            <input value="@Model.CurrentRole" class="profile-field profile-field-readonly" readonly />
                        </div>
                    </div>

                    <div class="action-buttons">
                        <a asp-page="Profile" class="btn btn-outline">
                            <i class="fas fa-arrow-left"></i> Назад
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Сохранить
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}