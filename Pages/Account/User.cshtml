@page
@model dancelog.Pages.Account.UserModel
@{
    ViewData["Title"] = Model.User.Id == 0 ? "Добавить пользователя" : "Редактировать пользователя";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --light-gray: #f8f9fa;
        --lighter-gray: #f0f0f0;
        --border-color: #e0e0e0;
        --shadow-sm: 0 2px 6px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.1);
        --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
        --card-border-radius: 16px;
        --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        --bg-color: #ffffff;
        --card-bg: #ffffff;
        --text-color: #212529; /* Черный цвет текста по умолчанию */
    }

    body {
        background-color: #f5f7fa;
    }

    .container {
        max-width: 800px;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-card {
        border: none;
        border-radius: var(--card-border-radius);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        background: var(--card-bg);
        transition: var(--transition);
        color: var(--text-color);
    }

    .card-header {
        background: var(--primary-gradient);
        color: white;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }

        .card-header::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
        }

        .card-header h4 {
            position: relative;
            z-index: 1;
            font-weight: 600;
            margin-bottom: 0;
        }

    .card-body {
        padding: 2rem;
    }

    .form-label {
        font-weight: 500;
        color: var(--text-color);
        margin-bottom: 0.5rem;
    }

    .form-control {
        border-radius: 10px;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border-color);
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
        background-color: var(--bg-color);
        color: var(--text-color); /* Важное изменение - цвет текста */
    }

        .form-control:focus {
            border-color: var(--primary-dark);
            box-shadow: 0 0 0 0.25rem rgba(106, 17, 203, 0.25);
        }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 0.25rem;
        color: #dc3545;
    }

    .btn {
        border-radius: 12px;
        padding: 10px 24px;
        font-weight: 500;
        letter-spacing: 0.5px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
        z-index: 1;
    }

    .btn-primary {
        background: var(--primary-gradient);
        border: none;
        box-shadow: var(--shadow-sm);
        background-size: 200% 200%;
    }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(37, 117, 252, 0.4);
            animation: gradientFlow 3s ease infinite;
        }

        .btn-primary:active {
            transform: translateY(1px);
            box-shadow: 0 2px 10px rgba(37, 117, 252, 0.3);
        }

    .btn-outline-secondary {
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        background-color: transparent;
    }

        .btn-outline-secondary:hover {
            background: var(--lighter-gray);
            color: var(--text-color);
        }

    @@keyframes gradientFlow {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .role-selector {
        display: flex;
        gap: 10px;
        margin-bottom: 20px;
    }

    .role-option {
        flex: 1;
        position: relative;
    }

        .role-option input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .role-option label {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            padding: 15px 10px;
            border: 2px solid var(--border-color);
            border-radius: 8px;
            background-color: var(--bg-color);
            cursor: pointer;
            transition: var(--transition);
            text-align: center;
            height: 100%;
            color: var(--text-color);
        }

            .role-option label:hover {
                border-color: var(--primary-light);
                transform: translateY(-3px);
                box-shadow: var(--shadow-sm);
            }

        .role-option input[type="radio"]:checked + label {
            border-color: var(--primary-dark);
            background: linear-gradient(135deg, rgba(106, 17, 203, 0.1) 0%, rgba(37, 117, 252, 0.1) 100%);
            color: var(--primary-dark);
            font-weight: 600;
        }

    .role-icon {
        font-size: 1.5rem;
        margin-bottom: 8px;
        color: var(--text-muted);
    }

    .role-option input[type="radio"]:checked + label .role-icon {
        color: var(--primary-dark);
    }

    .group-select-container {
        display: none;
        margin-bottom: 20px;
        animation: fadeIn 0.5s ease-out;
        background-color: var(--bg-color); /* Добавлено */
        border-radius: 10px; /* Добавлено */
        padding: 15px; /* Добавлено */
        border: 1px solid var(--border-color); /* Добавлено */
    }

    .group-select {
        width: 100%;
        padding: 0.75rem 1rem;
        border-radius: 10px;
        border: 1px solid var(--border-color);
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
        background-color: var(--bg-color);
        color: var(--text-color);
    }

        .group-select:focus {
            border-color: var(--primary-dark);
            box-shadow: 0 0 0 0.25rem rgba(106, 17, 203, 0.25);
        }

    .form-group {
        animation: slideUp 0.5s ease-out forwards;
        opacity: 0;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-group:nth-child(1) {
        animation-delay: 0.1s;
    }

    .form-group:nth-child(2) {
        animation-delay: 0.2s;
    }

    .form-group:nth-child(3) {
        animation-delay: 0.3s;
    }

    .form-group:nth-child(4) {
        animation-delay: 0.4s;
    }

    .form-group:nth-child(5) {
        animation-delay: 0.5s;
    }


    select option {
        background-color: var(--bg-color);
        color: var(--text-color);
    }

    .dark-theme {
        --bg-color: #1a1a1a;
        --card-bg: #121212;
        --text-color: #f8f9fa; /* Белый цвет текста в темной теме */
        --light-gray: #121212;
        --lighter-gray: #121212;
        --border-color: #495057;
        --primary-gradient: linear-gradient(135deg, #8a2be2 0%, #4b6cb7 100%);
        --primary-light: #4b6cb7;
        --primary-dark: #8a2be2;
        --text-muted: #adb5bd;
        --text-danger: #ff6b6b;
    }

        .dark-theme .form-control {
            background-color: var(--light-gray);
            color: var(--text-color); /* Убедимся, что цвет текста белый */
        }

        .dark-theme .group-select {
            background-color: var(--light-gray);
            color: var(--text-color);
        }

        .dark-theme .role-option label {
            background-color: var(--light-gray);
        }

        .dark-theme .btn-outline-secondary {
            background-color: transparent;
        }

            .dark-theme .btn-outline-secondary:hover {
                background-color: var(--lighter-gray);
            }

    .theme-toggle-container {
        position: absolute;
        top: 20px;
        right: 20px;
    }

    .theme-toggle-btn {
        background: none;
        border: none;
        color: white;
        font-size: 1.2rem;
        cursor: pointer;
    }

    .dark-theme .theme-toggle-btn {
        color: var(--text-color);
    }
</style>

<div class="container py-5">
    <div class="form-card" id="formCard">
        <div class="theme-toggle-container">
            <button class="theme-toggle-btn" id="themeToggle">
                <i class="fas fa-moon"></i>
            </button>
        </div>

        <div class="card-header">
            <h4 class="mb-0">@ViewData["Title"]</h4>
        </div>

        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="User.Id" />

                <div class="mb-4 form-group">
                    <label asp-for="User.Email" class="form-label">Email</label>
                    <input asp-for="User.Email" class="form-control" required />
                    <span asp-validation-for="User.Email" class="text-danger"></span>
                </div>

                <div class="row">
                    <div class="col-md-4 mb-4 form-group">
                        <label asp-for="User.LastName" class="form-label">Фамилия</label>
                        <input asp-for="User.LastName" class="form-control" required />
                        <span asp-validation-for="User.LastName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-4 form-group">
                        <label asp-for="User.FirstName" class="form-label">Имя</label>
                        <input asp-for="User.FirstName" class="form-control" required />
                        <span asp-validation-for="User.FirstName" class="text-danger"></span>
                    </div>

                    <div class="col-md-4 mb-4 form-group">
                        <label asp-for="User.MiddleName" class="form-label">Отчество</label>
                        <input asp-for="User.MiddleName" class="form-control" />
                        <span asp-validation-for="User.MiddleName" class="text-danger"></span>
                    </div>
                </div>

                <div class="mb-4 form-group">
                    <label asp-for="User.Password" class="form-label">Пароль</label>
                    <input asp-for="User.Password" class="form-control" required />
                    <span asp-validation-for="User.Password" class="text-danger"></span>
                </div>

                <div class="mb-4 form-group">
                    <label class="form-label">Роль пользователя</label>
                    <div class="role-selector">
                        <div class="role-option">
                            <input type="radio" asp-for="User.Role" id="roleAdmin" value="Админ">
                            <label for="roleAdmin">
                                <i class="fas fa-user-shield role-icon"></i>
                                Админ
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" asp-for="User.Role" id="roleTeacher" value="Учитель">
                            <label for="roleTeacher">
                                <i class="fas fa-chalkboard-teacher role-icon"></i>
                                Учитель
                            </label>
                        </div>
                        <div class="role-option">
                            <input type="radio" asp-for="User.Role" id="roleStudent" value="Ученик">
                            <label for="roleStudent">
                                <i class="fas fa-user-graduate role-icon"></i>
                                Ученик
                            </label>
                        </div>
                    </div>
                    <span asp-validation-for="User.Role" class="text-danger"></span>
                </div>

                <div id="groupSelectContainer" class="group-select-container form-group">
                    <label asp-for="User.GroupId" class="form-label">Группа</label>
                    <select asp-for="User.GroupId" asp-items="@Model.GroupOptions" class="group-select">
                        <option value="">Выберите группу</option>
                    </select>
                    <span asp-validation-for="User.GroupId" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-page="ListOfUsers" class="btn btn-outline-secondary me-3">
                        <i class="fas fa-times me-2"></i>Отмена
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>@(Model.User.Id == 0 ? "Добавить" : "Сохранить")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Устанавливаем выбранную роль при загрузке страницы
            const currentRole = '@Model.User.Role';
            if (currentRole) {
                const radio = document.querySelector(`input[type="radio"][value="${currentRole}"]`);
                if (radio) {
                    radio.checked = true;
                    toggleGroupSelect(currentRole === 'Ученик');
                }
            }

            // Обработка изменения роли
            document.querySelectorAll('input[name="User.Role"]').forEach(radio => {
                radio.addEventListener('change', function() {
                    toggleGroupSelect(this.value === 'Ученик');
                });
            });

            // Функция для показа/скрытия выбора группы
            function toggleGroupSelect(show) {
                const container = document.getElementById('groupSelectContainer');
                const select = container.querySelector('select');

                if (show) {
                    container.style.display = 'block';
                    select.setAttribute('required', 'required');
                } else {
                    container.style.display = 'none';
                    select.removeAttribute('required');
                    select.value = '';
                }
            }

            // Переключение темы
            const themeToggle = document.getElementById('themeToggle');
            const formCard = document.getElementById('formCard');

            // Проверяем сохраненную тему
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                formCard.classList.add('dark-theme');
                themeToggle.innerHTML = '<i class="fas fa-sun"></i>';
            }

            themeToggle.addEventListener('click', function() {
                formCard.classList.toggle('dark-theme');
                const isDark = formCard.classList.contains('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                themeToggle.innerHTML = isDark ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
            });
        });
    </script>
}