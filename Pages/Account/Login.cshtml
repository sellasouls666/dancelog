<div class="container py-5">
    <div class="login-container">
        <div class="login-card">
            <div class="card-body p-4 p-md-5">
                <!-- Аватарка с градиентом и анимацией -->
                <div class="login-avatar">
                    <i class="fas fa-sign-in-alt"></i>
                </div>

                <!-- Заголовок с полоской под словом "Вход" -->
                <h3 class="login-title text-center mb-4">
                    <span class="title-word">Вход</span> в систему
                </h3>

                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input asp-for="Input.Email" class="form-control" placeholder="Введите ваш email" />
                        <span asp-validation-for="Input.Email" class="text-danger"></span>
                    </div>

                    <div class="mb-3">
                        <label class="form-label">Пароль</label>
                        <input asp-for="Input.Password" type="password" class="form-control" placeholder="Введите ваш пароль" />
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>

                    <button type="submit" class="btn btn-login mb-3">
                        <i class="fas fa-sign-in-alt me-2"></i> Войти
                    </button>

                    <div class="register-link">
                        Нет аккаунта? <a asp-page="./Register">Зарегистрироваться</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}