@page
@model dancelog.Pages.Account.ProfilePageModel
@{
    ViewData["Title"] = "Профиль";
}

<h2>Профиль пользователя</h2>

<div class="card">
    <div class="card-body">
        <h4 class="card-title">Информация о пользователе</h4>
        <div class="mb-3">
            <label class="form-label">Имя</label>
            <input type="text" class="form-control" value="@Model.CurrentUser.FirstName" readonly />
        </div>
        <div class="mb-3">
            <label class="form-label">Фамилия</label>
            <input type="text" class="form-control" value="@Model.CurrentUser.LastName" readonly />
        </div>
        <div class="mb-3">
            <label class="form-label">Отчество</label>
            <input type="text" class="form-control" value="@Model.CurrentUser.MiddleName" readonly />
        </div>
        <div class="mb-3">
            <label class="form-label">Email</label>
            <input type="email" class="form-control" value="@Model.CurrentUser.Email" readonly />
        </div>
        <div class="mb-3">
            <label class="form-label">Роль</label>
            <input type="text" class="form-control" value="@Model.CurrentUser.Role" readonly />
        </div>
        <a asp-page="/Index" class="btn btn-secondary">На главную</a>
        <a asp-page="EditProfile" class="btn btn-primary">Редактировать профиль</a>
    </div>
</div>