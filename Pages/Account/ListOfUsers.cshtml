@page
@model dancelog.Pages.Account.ListOfUsersModel
@{
    ViewData["Title"] = "Список пользователей";
}

<style>
    .card {
        transition: transform 0.2s ease-in-out;
    }

        .card:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }

    .btn-user-action {
        transition: all 0.2s ease;
    }

        .btn-user-action:hover {
            transform: scale(1.05);
        }
</style>

<div class="container py-4">
    @if (Model.Users != null && Model.Users.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">@ViewData["Title"]</h1>
            <a href="@Url.Page("User", new { id = 0 })" class="btn btn-outline-dark">
                <i class="fas fa-plus me-1"></i> Создать пользователя
            </a>
        </div>

        <div class="row g-4">
            @foreach (var user in Model.Users)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">@user.FullName</h5>
                            <p class="card-text text-muted small mb-1">
                                <i class="fas fa-envelope me-1"></i> @user.Email
                            </p>
                            <p class="card-text">
                                <span class="badge bg-secondary">@user.Role</span>
                            </p>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-flex justify-content-end">
                                <a href="@Url.Page("User", new { id = user.Id })"
                                   class="btn btn-sm btn-outline-secondary me-2 btn-user-action">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="javascript:void(0);"
                                   onclick="confirmDelete(@user.Id)"
                                   class="btn btn-sm btn-outline-secondary btn-user-action">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="card shadow-sm">
                <div class="card-body py-5">
                    <h4 class="mt-3">Нет добавленных пользователей</h4>
                    <p class="text-muted">Нажмите кнопку ниже, чтобы создать пользователя</p>
                    <a href="@Url.Page("User", new { id = 0 })" class="btn btn-outline-dark mt-3">
                        <i class="fas fa-plus me-1"></i> Создать нового пользователя
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить этого пользователя?')) {
                window.location.href = '@Url.Page("UserDelete")' + '?id=' + id;
            }
        }
    </script>
}