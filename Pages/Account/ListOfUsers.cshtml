@page
@model dancelog.Pages.Account.ListOfUsersModel
@{
    ViewData["Title"] = "Список пользователей";
}

<h2>@ViewData["Title"]</h2>

<p>
    <a asp-page="User" class="btn btn-primary">Добавить пользователя</a>
</p>

<table class="table table-bordered table-striped">
    <thead class="thead-dark">
        <tr>
            <th>ID</th>
            <th>Email</th>
            <th>Фамилия</th>
            <th>Имя</th>
            <th>Отчество</th>
            <th>ФИО</th>
            <th>Роль</th>
            <th>Пароль</th>
            <th>Действия</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model.Users)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.Email</td>
                <td>@user.LastName</td>
                <td>@user.FirstName</td>
                <td>@user.MiddleName</td>
                <td>@user.FullName</td>
                <td>@user.Role</td>
                <td>@user.Password</td>
                <td>
                    <a asp-page="User" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Редактировать</a>
                </td>
            </tr>
        }
    </tbody>
</table>