@page
@model dancelog.Pages.ListOfStudentsModel
@{
    ViewData["Title"] = "Список студентов";
}

<style>
    .card {
        transition: transform 0.2s ease-in-out;
    }

        .card:hover {
            transform: scale(1.03);
            box-shadow: 0 10px 20px rgba(0,0,0,0.1);
        }
</style>

<div class="container py-4">
    @if (Model.Students.Any())
    {
        <div class="d-flex justify-content-between align-items-center mb-4">
            <h1 class="mb-0">@ViewData["Title"]</h1>
            <a href="@Url.Page("Student", new { id = 0 })" class="btn btn-outline-dark">
                Добавить студента
            </a>
        </div>

        <div class="row g-4">
            @foreach (var student in Model.Students)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-body">
                            <h5 class="card-title">@student.Surname</h5>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item">@student.Name</li>
                            <li class="list-group-item">@student.Patronymic</li>
                            <li class="list-group-item">@student.Group?.Name</li>
                            <li class="list-group-item">@student.Email</li>
                            <li class="list-group-item">@student.PhoneNumber</li>
                        </ul>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="d-flex justify-content-end">
                                <a href="@Url.Page("Student", new { id = student.Id })"
                                   class="btn btn-sm btn-outline-secondary me-2">
                                    Изменить
                                </a>
                                <a href="javascript:void(0);"
                                   onclick="confirmDelete(@student.Id)"
                                   class="btn btn-sm btn-outline-secondary">
                                    Удалить
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5">
            <div class="card shadow-sm">
                <div class="card-body py-5">
                    <h4 class="mt-3">Нет добавленных студентов</h4>
                    <p class="text-muted">Нажмите кнопку ниже, чтобы добавить студента</p>
                    <a href="@Url.Page("Student", new { id = 0 })" class="btn btn-outline-dark mt-3">
                        Добавить студента
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить этого студента?')) {
                window.location.href = '@Url.Page("StudentDelete")' + '?id=' + id;
            }
        }
    </script>
}
