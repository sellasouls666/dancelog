@page
@model dancelog.Pages.ListOfCourseModel
@{
    ViewData["Title"] = "Список курсов";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #a0a0a0;
        --light-gray: #2a2a2a;
        --lighter-gray: #1e1e1e;
        --border-color: #333;
        --shadow-sm: 0 1px 3px rgba(0, 0, 0, 0.4);
        --shadow-md: 0 4px 6px rgba(0, 0, 0, 0.5);
        --shadow-lg: 0 10px 15px rgba(0, 0, 0, 0.6);
        --card-border-radius: 12px;
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        --bg-color: #ffffff;
        --card-bg: #ffffff;
        --text-color: #000000;
        --border-color: #dee2e6;
        --table-bg: #ffffff;
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    }

    body.dark-theme {
        --bg-color: #121212;
        --card-bg: #1f1f1f;
        --text-color: #f1f1f1;
        --border-color: #333;
        --table-bg: #1a1a1a;
    }

    body {
        --bg-color: #ffffff;
        --card-bg: #ffffff;
        --text-color: #000000;
        --border-color: #dee2e6;
        --table-bg: #ffffff;
    }

    .btn-course-action {
        position: relative;
        background-color: transparent;
        color: var(--primary-light);
        border: none;
        z-index: 1;
    }

        .btn-course-action::before {
            content: '';
            position: absolute;
            top: -2px;
            left: -2px;
            right: -2px;
            bottom: -2px;
            background: var(--primary-gradient);
            border-radius: 8px;
            z-index: -1;
            mask: linear-gradient(#fff 0 0) content-box, linear-gradient(#fff 0 0);
            mask-composite: exclude;
            -webkit-mask-composite: destination-out;
            padding: 2px;
        }

        /* Optional: Hover effect to make it pop */
        .btn-course-action:hover {
            color: #fff;
        }

            .btn-course-action:hover::before {
                filter: brightness(1.2);
            }

    .container {
        max-width: 1400px;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-header {
        position: relative;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

        .page-header h1 {
            font-weight: 600;
            position: relative;
            display: inline-block;
            margin-bottom: 0;
            color: var(--text-color); /* ← вот так */
        }

            .page-header h1::after {
                content: "";
                position: absolute;
                bottom: -8px;
                left: 0;
                width: 60px;
                height: 4px;
                background: var(--primary-gradient);
                border-radius: 4px;
                transition: width 0.6s ease;
            }

            .page-header h1:hover::after {
                width: 100px;
            }

    .card {
        border: 1px solid var(--border-color); /* например #ccc */
        border-radius: 12px;
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        background: #1f1f1f;
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
        height: 100%;
        color: var(--text-color);
        background-color: var(--card-bg); /* в светлой теме пусть будет #ffffff */
        color: var(--text-color);
        border-color: var(--border-color);
        box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
        transition: all 0.3s ease;

    }

        .card:hover {
            transform: scale(1.03);
            box-shadow: var(--shadow-lg);
        }

    .btn-course-action {
        transition: transform 0.2s ease, background 0.2s ease;
        color: var(--primary-light);
        border-color: var(--primary-light);
    }

        .btn-course-action:hover {
            transform: scale(1.05);
            background: var(--primary-gradient);
            border-color: var(--primary-gradient);
            color: #fff;
        }

    .action-buttons {
        display: flex;
        justify-content: center;
        gap: 10px;
    }

    .empty-state .card-body {
        text-align: center;
    }

    .text-muted {
        color: var(--text-muted) !important;
    }

    table {
        background-color: var(--table-bg);
        color: var(--text-color);
    }
</style>

<div class="container py-4">
    @if (Model.Courses.Any())
    {
        <div class="d-flex justify-content-between align-items-center page-header">
            <h1>@ViewData["Title"]</h1>
            <a href="@Url.Page("Course", new { id = 0 })" class="btn btn-create btn-course-action">
                <i class="fas fa-plus me-1"></i> Добавить курс
            </a>
        </div>

        <div class="row g-4">
            @foreach (var course in Model.Courses)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card">
                        <div class="card-body d-flex align-items-center justify-content-center">
                            <h5 class="card-title text-center mb-0">@course.Name</h5>
                        </div>
                        <div class="card-footer bg-transparent border-top-0">
                            <div class="action-buttons">
                                <a href="@Url.Page("Course", new { id = course.Id })"
                                   class="btn btn-sm btn-outline-secondary btn-course-action" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="javascript:void(0);"
                                   onclick="confirmDelete(@course.Id)"
                                   class="btn btn-sm btn-outline-secondary btn-course-action" title="Удалить">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 empty-state">
            <div class="card mx-auto" style="max-width: 400px;">
                <div class="card-body py-5">
                    <h4 class="mt-3">Нет добавленных курсов</h4>
                    <p class="text-muted">Нажмите кнопку ниже, чтобы создать курс</p>
                    <a href="@Url.Page("Course", new { id = 0 })"
                       class="btn btn-create btn-course-action mt-3">
                        <i class="fas fa-plus me-1"></i> Создать новый курс
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить этот курс?')) {
                window.location.href = '@Url.Page("CourseDelete")' + '?id=' + id;
            }
        }
                function toggleTheme() {
            document.body.classList.toggle('dark-theme');
        }
    </script>
}
