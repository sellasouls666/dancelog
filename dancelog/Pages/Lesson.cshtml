@page
@model dancelog.Pages.LessonModel
@{
    ViewData["Title"] = Model.IsNew ? "Добавить занятие" : "Редактировать занятие";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --light-gray: #f8f9fa;
        --lighter-gray: #f0f0f0;
        --border-color: #e0e0e0;
        --shadow-sm: 0 2px 6px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.1);
        --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
        --card-border-radius: 16px;
        --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        --bg-color: #ffffff;
        --card-bg: #ffffff;
        --text-color: #212529;
    }

    body {
        background-color: #f5f7fa;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
    }

    .container {
        max-width: 800px;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-card {
        border: none;
        border-radius: var(--card-border-radius);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        background: var(--card-bg);
        transition: var(--transition);
        color: var(--text-color);
        margin-top: 2rem;
    }

    .card-header {
        background: var(--primary-gradient);
        color: white;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }

        .card-header::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
        }

        .card-header h1 {
            position: relative;
            z-index: 1;
            font-weight: 600;
            margin-bottom: 0;
            font-size: 1.8rem;
        }

    .card-body {
        padding: 2rem;
    }

    .form-label {
        font-weight: 500;
        color: var(--text-color);
        margin-bottom: 0.5rem;
        display: block;
    }

    .form-control, .form-select {
        border-radius: 10px;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border-color);
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
        background-color: var(--bg-color);
        color: var(--text-color);
        width: 100%;
    }

        .form-control:focus, .form-select:focus {
            border-color: var(--primary-dark);
            box-shadow: 0 0 0 0.25rem rgba(106, 17, 203, 0.25);
        }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 0.25rem;
        color: #dc3545;
    }

    .btn {
        border-radius: 12px;
        padding: 10px 24px;
        font-weight: 500;
        letter-spacing: 0.5px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
        z-index: 1;
    }

    .btn-primary {
        background: var(--primary-gradient);
        border: none;
        box-shadow: var(--shadow-sm);
        background-size: 200% 200%;
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 25px rgba(37, 117, 252, 0.4);
            animation: gradientFlow 3s ease infinite;
        }

        .btn-primary:active {
            transform: translateY(1px);
            box-shadow: 0 2px 10px rgba(37, 117, 252, 0.3);
        }

    .btn-secondary {
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        background-color: transparent;
    }

        .btn-secondary:hover {
            background: var(--lighter-gray);
            color: var(--text-color);
        }

    @@keyframes gradientFlow {
        0% {
            background-position: 0% 50%;
        }

        50% {
            background-position: 100% 50%;
        }

        100% {
            background-position: 0% 50%;
        }
    }

    .form-group {
        margin-bottom: 1.5rem;
        animation: slideUp 0.5s ease-out forwards;
        opacity: 0;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-group:nth-child(1) {
        animation-delay: 0.1s;
    }

    .form-group:nth-child(2) {
        animation-delay: 0.2s;
    }

    .form-group:nth-child(3) {
        animation-delay: 0.3s;
    }

    .form-group:nth-child(4) {
        animation-delay: 0.4s;
    }

    .form-group:nth-child(5) {
        animation-delay: 0.5s;
    }

    .dark-theme {
        --bg-color: #1a1a1a;
        --card-bg: #121212;
        --text-color: #f8f9fa;
        --light-gray: #121212;
        --lighter-gray: #121212;
        --border-color: #495057;
        --primary-gradient: linear-gradient(135deg, #8a2be2 0%, #4b6cb7 100%);
        --primary-light: #4b6cb7;
        --primary-dark: #8a2be2;
        --text-muted: #adb5bd;
        --text-danger: #ff6b6b;
    }

        .dark-theme .form-control,
        .dark-theme .form-select {
            background-color: var(--light-gray);
            color: var(--text-color);
            border-color: var(--border-color);
        }

        .dark-theme .btn-secondary {
            background-color: transparent;
            border-color: var(--border-color);
        }

            .dark-theme .btn-secondary:hover {
                background-color: var(--lighter-gray);
            }

    .theme-toggle-container {
        position: absolute;
        top: 20px;
        right: 20px;
    }

    .theme-toggle-btn {
        background: none;
        border: none;
        color: white;
        font-size: 1.2rem;
        cursor: pointer;
    }

    .dark-theme .theme-toggle-btn {
        color: var(--text-color);
    }

    .time-slot-option {
        padding: 0.75rem 1rem;
        border-radius: 8px;
        transition: var(--transition);
    }

        .time-slot-option:hover {
            background-color: rgba(37, 117, 252, 0.1);
        }

    .dark-theme .time-slot-option:hover {
        background-color: rgba(75, 108, 183, 0.2);
    }
</style>

<div class="container">
    <div class="form-card" id="formCard">
        <div class="theme-toggle-container">
            <button class="theme-toggle-btn" id="themeToggle">
                <i class="fas fa-moon"></i>
            </button>
        </div>

        <div class="card-header">
            <h1>@ViewData["Title"]</h1>
        </div>

        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="Lesson.Id" value="@(Model.Lesson?.Id ?? 0)" />
                <input type="hidden" asp-for="SlotFromQuery" value="@Model.SlotFromQuery" />

                <div class="form-group">
                    <label asp-for="Lesson.Name" class="form-label">Название урока</label>
                    <input asp-for="Lesson.Name" class="form-control" />
                    <span asp-validation-for="Lesson.Name" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="Lesson.GroupId" class="form-label">Группа</label>
                    <select asp-for="Lesson.GroupId"
                            class="form-select"
                            asp-items="@Model.Groups">
                        <option value="">Выберите группу</option>
                    </select>
                    <span asp-validation-for="Lesson.GroupId" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="LessonDate" class="form-label">Дата</label>
                    <input asp-for="LessonDate"
                           type="date"
                           asp-format="{0:yyyy-MM-dd}"
                           class="form-control" />
                    <span asp-validation-for="LessonDate" class="text-danger"></span>
                </div>

                <div class="form-group">
                    <label asp-for="SelectedTimeSlot" class="form-label">Время</label>
                    <select asp-for="SelectedTimeSlot" class="form-select">
                        <option value="">Выберите время</option>
                        <option value="First">Первая пара (8:00–9:35)</option>
                        <option value="Second">Вторая пара (9:45–11:20)</option>
                        <option value="Third">Третья пара (11:50–13:25)</option>
                        <option value="Fourth">Четвёртая пара (13:35–15:10)</option>
                        <option value="Extra">Доп. урок</option>
                    </select>
                    <span asp-validation-for="SelectedTimeSlot" class="text-danger"></span>
                </div>

                <div class="form-group" id="extraTimeDiv" style="display:none;">
                    <label asp-for="ExtraTime" class="form-label">Время для доп. урока</label>
                    <input asp-for="ExtraTime" type="time" class="form-control" />
                    <span asp-validation-for="ExtraTime" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-page="./ListOfLessons" class="btn btn-secondary me-3">
                        <i class="fas fa-times me-2"></i>Отмена
                    </a>
                    <button type="submit" class="btn btn-primary">
                        <i class="fas fa-save me-2"></i>Сохранить
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            // Обработка дополнительного времени
            const timeSlotSelect = document.querySelector('select[name="SelectedTimeSlot"]');
            const extraTimeDiv = document.getElementById('extraTimeDiv');

            function toggleExtraTime() {
                const isExtra = timeSlotSelect.value === 'Extra';
                extraTimeDiv.style.display = isExtra ? 'block' : 'none';
                if (isExtra) {
                    document.querySelector('input[name="ExtraTime"]').required = true;
                } else {
                    document.querySelector('input[name="ExtraTime"]').required = false;
                }
            }

            timeSlotSelect.addEventListener('change', toggleExtraTime);
            toggleExtraTime(); // Инициализация при загрузке

            // Переключение темы
            const themeToggle = document.getElementById('themeToggle');
            const formCard = document.getElementById('formCard');

            // Проверяем сохраненную тему
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                formCard.classList.add('dark-theme');
                themeToggle.innerHTML = '<i class="fas fa-sun"></i>';
            }

            themeToggle.addEventListener('click', function() {
                formCard.classList.toggle('dark-theme');
                const isDark = formCard.classList.contains('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                themeToggle.innerHTML = isDark ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
            });
        });
    </script>
}