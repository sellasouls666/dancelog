@page
@model dancelog.Pages.ListOfCourseModel
@{
    ViewData["Title"] = "Список курсов";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --light-gray: #f8f9fa;
        --lighter-gray: #f0f0f0;
        --border-color: #e0e0e0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
        --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
        --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
        --card-border-radius: 12px;
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        --card-bg: #ffffff;
        --text-color: #212529;
        --btn-text-color: #212529; /* Цвет текста кнопок по умолчанию */
        --btn-icon-color: #212529; /* Цвет иконок по умолчанию */
    }

    body {
        background: linear-gradient(to bottom, #f5f7fa 0%, #e4e8eb 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
    }

        body.dark-theme {
            --text-muted: #a0a0a0;
            --light-gray: #2a2a2a;
            --lighter-gray: #1e1e1e;
            --border-color: #444;
            --card-bg: #121212;
            --text-color: #f1f1f1;
            --btn-text-color: #ffffff; /* Белый текст кнопок в темной теме */
            --btn-icon-color: #ffffff; /* Белые иконки в темной теме */
            background: #000000 !important;
        }

    /* Остальные стили остаются без изменений */
    .container {
        max-width: 1400px;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-header {
        position: relative;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

        .page-header h1 {
            font-weight: 600;
            position: relative;
            display: inline-block;
            margin-bottom: 0;
            color: var(--text-color);
        }

            .page-header h1::after {
                content: "";
                position: absolute;
                bottom: -8px;
                left: 0;
                width: 60px;
                height: 4px;
                background: var(--primary-gradient);
                border-radius: 4px;
                transition: width 0.6s ease;
            }

            .page-header h1:hover::after {
                width: 100px;
            }

    .card {
        border: none;
        border-radius: var(--card-border-radius);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        background: var(--card-bg);
        transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.3s;
        display: flex;
        flex-direction: column;
        height: 100%;
        color: var(--text-color);
    }

        .card:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: var(--shadow-lg);
        }

    .card-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.5rem;
        text-align: center;
    }

    .card-title {
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
        color: var(--text-color);
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        margin-top: auto;
        margin-top: 1.2rem;
        justify-content: center;
    }

    .btn-course-action {
        position: relative;
        background: transparent !important;
        color: var(--btn-text-color) !important;
        border: 2px solid transparent !important;
        border-image-source: var(--primary-gradient) !important;
        border-image-slice: 1 !important;
        border-image-repeat: stretch !important;
        border-radius: var(--card-border-radius) !important;
        transition: transform 0.2s ease, background 0.2s ease;
    }

        .btn-course-action i {
            color: var(--btn-icon-color) !important;
        }

        .btn-course-action:hover {
            transform: scale(1.1);
            background: var(--primary-gradient) !important;
            color: #fff !important;
        }

            .btn-course-action:hover i {
                color: #fff !important;
            }

    .empty-state .card-body {
        text-align: center;
    }

    .btn-create {
        position: relative;
        background: transparent !important;
        color: var(--btn-text-color) !important;
        border: 2px solid transparent !important;
        border-image-source: var(--primary-gradient) !important;
        border-image-slice: 1 !important;
        border-image-repeat: stretch !important;
        border-radius: var(--card-border-radius) !important;
        transition: transform 0.2s ease, background 0.2s ease;
    }

        .btn-create i {
            color: var(--btn-icon-color) !important;
        }

        .btn-create:hover {
            transform: scale(1.05);
            background: var(--primary-gradient) !important;
            color: #fff !important;
        }

            .btn-create:hover i {
                color: #fff !important;
            }

    .text-muted {
        color: var(--text-muted) !important;
    }
</style>

<div class="container py-4">
    @if (Model.Courses.Any())
    {
        <div class="d-flex justify-content-between align-items-center page-header">
            <h1>@ViewData["Title"]</h1>
            <a href="@Url.Page("Course", new { id = 0 })" class="btn btn-create">
                <i class="fas fa-plus me-1"></i> Добавить курс
            </a>
        </div>

        <div class="row g-4">
            @foreach (var course in Model.Courses)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">@course.Name</h5>
                            <div class="action-buttons">
                                <a href="@Url.Page("Course", new { id = course.Id })"
                                   class="btn btn-sm btn-outline-secondary btn-course-action" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="javascript:void(0);" class="btn btn-sm btn-outline-secondary btn-course-action" onclick="if (confirm('Вы уверены, что хотите удалить этот курс?')) { window.location.href = '@Url.Page("CourseDelete", new { id = course.Id })'; }">Удалить</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 empty-state">
            <div class="card mx-auto" style="max-width: 400px;">
                <div class="card-body py-5">
                    <h4 class="mt-3">Нет добавленных курсов</h4>
                    <p class="text-muted">Нажмите кнопку ниже, чтобы создать курс</p>
                    <a href="@Url.Page("Course", new { id = 0 })"
                       class="btn btn-create mt-3">
                        <i class="fas fa-plus me-1"></i> Создать новый курс
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.0/signalr.min.js"></script>
    <script>
        const connection = new signalR.HubConnectionBuilder()
            .withUrl("/chathub")
            .build();

        connection.on("CourseUpdated", function (course) {
            const existingCard = document.getElementById("course-" + course.id);
            const html = `
                <div class="card">
                        <div class="card-body">
                            <h5 class="card-title">${course.name}</h5>
                            <div class="action-buttons">
                                <a href="/Course?id=${course.id}"
                                   class="btn btn-sm btn-outline-secondary btn-course-action" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="javascript:void(0);" class="btn btn-sm btn-outline-secondary btn-course-action" onclick="if (confirm('Вы уверены, что хотите удалить этот курс?')) { window.location.href = '/CourseDelete?id=${course.id}'; }">Удалить</a>
                            </div>
                        </div>
                    </div>`;

            if (existingCard) {
                existingCard.outerHTML = html;
            } else {
                const container = document.querySelector(".row");
                const wrapper = document.createElement("div");
                wrapper.className = "col";
                wrapper.innerHTML = html;
                container.appendChild(wrapper);
            }
        });

        connection.start().catch(err => console.error(err.toString()));
    </script>
    <script>
        /*function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить этот курс?')) {
                window.location.href = '@Url.Page("CourseDelete")' + '?id=' + id;
            }
        }*/

        function toggleTheme() {
            document.body.classList.toggle('dark-theme');
        }
    </script>
}