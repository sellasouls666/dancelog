    @page
    @model dancelog.Pages.ListOfStudentsModel
    @{
        ViewData["Title"] = "Список студентов";
    }



    <style>
        :root {
            /* Общие переменные */
            --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
            --primary-light: #2575fc;
            --primary-dark: #6a11cb;
            /* Цвета для светлой темы */
            --bg-page: linear-gradient(to bottom, #f5f7fa 0%, #e4e8eb 100%);
            --bg-card: #ffffff;
            --text-color: #343a40;
            --text-muted: #6c757d;
            --border-color: #e0e0e0;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
            --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
        }

        /* Переопределение для тёмной темы */
        body.dark-theme {
            --bg-page: #000000;
            --bg-card: #1e1e1e;
            --text-color: #e4e6eb;
            --text-muted: #8a8c8e;
            --border-color: #333333;
            --shadow-sm: 0 1px 3px rgba(0,0,0,0.6);
            --shadow-lg: 0 4px 6px rgba(0,0,0,0.8);
        }
        /* в тёмной теме: фиолетовая иконка и обводка */
    body.dark-theme .btn-student-action {
        color: var(--primary-dark);        /* иконка и текст — фиолетовые */
        border-color: var(--primary-dark); /* рамка — фиолетовая */
        background: transparent;           /* фон прозрачный, чтобы был цвет карточки */
    }
    body.dark-theme .btn-student-action i {
                color: inherit !important;
            }
                /* в тёмной теме: граница и иконка — фиолетовые как на втором скрине */
                body.dark-theme .btn-student-action.btn-outline-secondary {
                border: 2px solid transparent; /* ширину меняйте по вкусу */
                border-image-slice: 1;
                border-image-source: var(--primary-gradient);
                background: transparent !important; /* чтобы не перекрывался фон карточки */
                color: #fff !important;
            }

                    /* иконка наследует цвет кнопки */
                    body.dark-theme .btn-student-action.btn-outline-secondary i {
                        color: inherit !important;
                    }

            body.dark-theme .btn-student-action i {
                color: #fff !important;
            }

                    body.dark-theme .btn-student-action.btn-outline-secondary:hover {
                        border-color: var(--primary-dark) !important;
                        color: var(--primary-dark) !important;
                        background: rgba(106, 17, 203, 0.1); /* лёгкий фиолетовый фон при ховере */
                    }

            body.dark-theme .btn-student-action:hover {
                background: var(--primary-gradient) !important;
                border-image-source: var(--primary-gradient);
                color: #fff !important;
            }

        body {
            background: var(--bg-page);
            color: var(--text-color);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            transition: background 0.3s, color 0.3s;
        }

        .container {
            max-width: 1400px;
            animation: fadeIn 0.8s ease-out;
        }

        @@keyframes fadeIn {
            from

        {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }

        }

        .page-header {
            position: relative;
            padding-bottom: 0.5rem;
            margin-bottom: 1.5rem;
            border-bottom: 1px solid rgba(0,0,0,0.05);
        }

            .page-header h1 {
                font-weight: 600;
                display: inline-block;
                margin-bottom: 0;
                color: var(--text-color);
            }

                .page-header h1::after {
                    content: "";
                    position: absolute;
                    bottom: -8px;
                    left: 0;
                    width: 60px;
                    height: 4px;
                    background: var(--primary-gradient);
                    border-radius: 4px;
                    transition: width 0.6s ease;
                }

                .page-header h1:hover::after {
                    width: 100px;
                }

        .card {
            background: var(--bg-card);
            color: var(--text-color);
            border: none;
            border-radius: 12px;
            overflow: hidden;
            box-shadow: var(--shadow-sm);
            transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.3s, color 0.3s;
            display: flex;
            flex-direction: column;
            height: 100%;
        }

            .card:hover {
                transform: translateY(-5px) scale(1.02);
                box-shadow: var(--shadow-lg);
            }

        .card-body {
            flex: 1;
            display: flex;
            flex-direction: column;
            padding: 1.5rem;
        }

        .card-title {
            font-size: 1.25rem;
            margin-bottom: 0.75rem;
            color: var(--text-color);
        }

        .badge-group {
            display: inline-block;
            margin-bottom: 1rem;
            padding: 0.4rem 0.8rem;
            background: var(--primary-gradient);
            color: #fff;
            border-radius: 0.5rem;
            font-size: 0.85rem;
            font-weight: 500;
        }

        .list-group-item {
            background: transparent;
            border: none;
            border-bottom: 1px solid var(--border-color);
            padding: 0.75rem 0;
            color: var(--text-color);
        }

        .action-buttons {
            display: flex;
            gap: 0.5rem;
            margin-top: 1rem;
            justify-content: flex-end;
        }

        .btn-student-action {
            transition: transform 0.2s ease, background 0.2s ease;
            color: var(--primary-dark);
            border-color: var(--primary-dark);
        }

            .btn-student-action:hover {
                transform: scale(1.1);
            background: var(--primary-gradient) !important;
                border-color: var(--primary-gradient);
            color: #fff !important;
            }
        /* 1) Светлая тема — иконки чёрные, контур остаётся стандартным */
        .btn-student-action i {
            color: #000; /* чёрные иконки */
        }

        .empty-state .card-body {
            text-align: center;
        }

    .btn-student-action {
        /* фиксируем рамку: прозрачная основа + градиент сверху */
        border: 2px solid transparent;
        border-image-slice: 1;
        border-image-source: var(--primary-gradient);
        /* padding и box-sizing для постоянного размера */
        padding: 0.25rem 0.5rem; /* как у btn-sm */
        box-sizing: border-box;
        background: transparent !important;
        transition: transform 0.2s ease, background 0.2s ease;
    }

    </style>

    <div class="container py-4">
        @if (Model.Students != null && Model.Students.Any())
        {
            <div class="d-flex justify-content-between align-items-center page-header">
                <h1>@ViewData["Title"]</h1>
            </div>

            <div class="row g-4">
                @foreach (var student in Model.Students)
                {
                    <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title">@student.Surname @student.Name</h5>
                                @if (student.Group != null)
                                {
                                    <span class="badge-group">
                                        <i class="fas fa-layer-group me-1"></i> @student.Group.Name
                                    </span>
                                }
                                <ul class="list-group list-group-flush mb-3">
                                    <li class="list-group-item">@student.Patronymic</li>
                                    <li class="list-group-item"><i class="fas fa-envelope me-1"></i> @student.Email</li>
                                </ul>
                                <div class="action-buttons">
                                    <a href="@Url.Page("Student", new { id = student.Id })"
                                       class="btn btn-sm btn-outline-secondary btn-student-action" title="Изменить">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <a href="javascript:void(0);"
                                       onclick="confirmDelete(@student.Id)"
                                       class="btn btn-sm btn-outline-secondary btn-student-action" title="Удалить">
                                        <i class="fas fa-trash-alt"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
        else
        {
            <div class="text-center py-5 empty-state">
                <div class="card mx-auto" style="max-width: 400px;">
                    <div class="card-body py-5">
                        <h4 class="mt-3">Нет данных о студентах</h4>
                        <p class="text-muted">В системе пока нет студентов</p>
                    </div>
                </div>
            </div>
        }
    </div>

    @section Scripts {
        <script>
            function confirmDelete(id) {
                if (confirm('Вы уверены, что хотите удалить этого студента?')) {
                    window.location.href = '@Url.Page("StudentDelete")' + '?id=' + id;
                }
            }
        </script>
    }
