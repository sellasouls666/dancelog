<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - dancelog</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        /* Reset and base box-sizing */
        *, *::before, *::after {
            box-sizing: border-box;
        }

        html, body {
            margin: 0;
            padding: 0;
            height: 100%;
            min-height: 100%;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background-color: #fff;
            color: #212529;
            overflow-y: scroll; /* Always show vertical scrollbar to avoid layout shift */
        }

            body.dark-theme {
                background-color: #000;
                color: #e0e0e0;
            }

        /* Fixed Layout container to prevent movement */
        .fixed-layout-container {
            max-width: 1400px; /* fixed wide max width */
            margin-left: auto;
            margin-right: auto;
            padding-left: 30px;
            padding-right: 30px;
            min-height: 100vh;
            display: flex;
            flex-direction: column;
            /* Optional: prevent horizontal scroll */
            overflow-x: hidden;
        }

        header.navbar {
            width: 100%;
            box-shadow: 0 1px 4px rgba(0,0,0,0.1);
            background-color: #f8f9fa;
            position: sticky;
            top: 0;
            z-index: 1030;
        }

        /* Keep navbar brand and nav aligned */
        .navbar-container {
            max-width: 1400px;
            margin: 0 auto;
            padding: 0 30px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        /* Content area with flex-grow to fill available height */
        main.content-area {
            flex-grow: 1;
            padding-top: 20px;
            padding-bottom: 40px;
            /* Avoid shifting by always reserving space */
            min-height: calc(100vh - 60px); /* adjust based on header height */
        }

        /* Footer if exists */
        footer {
            max-width: 1400px;
            margin: 0 auto;
            padding: 20px 30px;
            text-align: center;
            color: #666;
            font-size: 14px;
        }
    </style>
</head>
<body>
    <div class="fixed-layout-container">
        <header class="navbar">
            <div class="navbar-container">
                <a class="navbar-brand d-flex align-items-center" href="/">
                    <img src="https://cdn-icons-png.flaticon.com/512/5969/5969724.png" alt="DanceLog" width="30" height="30" class="me-2" />
                    <span>DANCELOG</span>
                </a>
                <nav class="d-flex gap-3">
                    <a href="/ListOfCourse" class="nav-link">Курсы</a>
                    <a href="/ListOfGroups" class="nav-link">Группы</a>
                    <a href="/ListOfLessons" class="nav-link">Занятия</a>
                    <a href="/Chat" class="nav-link">Чат</a>
                </nav>
            </div>
        </header>

        <main class="content-area" role="main">
            @RenderBody()
        </main>

        <footer>
            &copy; 2024 DanceLog. Все права защищены.
        </footer>
    </div>

    <script src="https://code.jquery.com/jquery-3.7.0.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

