@page
@model dancelog.Pages.Account.EditProfileModel
@{
    ViewData["Title"] = "Редактирование профиля";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --light-gray: #f8f9fa;
        --lighter-gray: #f0f0f0;
        --border-color: #e0e0e0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
        --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
        --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        --bg-color: #ffffff;
        --card-bg: #ffffff;
        --text-color: #212529;
    }

    body {
        background-color: #f5f7fa;
    }

    .profile-container {
        max-width: 520px;
        margin: 2rem auto;
        animation: fadeIn 0.5s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(10px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .profile-card {
        border: none;
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        background: var(--card-bg);
        position: relative;
        color: var(--text-color);
    }

    .form-group {
        margin-bottom: 1.5rem;
        position: relative;
    }

    .form-label {
        display: block;
        margin-bottom: 0.5rem;
        font-size: 0.875rem;
        color: var(--text-muted);
        font-weight: 500;
        text-align: left;
    }

    .profile-field {
        border: none;
        border-radius: 10px;
        padding: 12px 16px;
        background-color: var(--light-gray);
        transition: var(--transition);
        width: 100%;
        font-size: 0.95rem;
        color: var(--text-color);
        box-shadow: var(--shadow-sm);
    }

        .profile-field:hover {
            box-shadow: var(--shadow-md);
            background-color: var(--lighter-gray);
        }

        .profile-field:focus {
            box-shadow: 0 0 0 3px rgba(37, 117, 252, 0.2);
            outline: none;
            background-color: var(--bg-color);
        }

    .readonly-section {
        background-color: var(--light-gray);
        border-radius: 12px;
        padding: 1.5rem;
        margin-top: 1.5rem;
        box-shadow: var(--shadow-sm);
    }

    .readonly-section-title {
        font-size: 1.5rem;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
        text-align: center;
    }

    .profile-field-readonly {
        background-color: var(--lighter-gray);
        cursor: not-allowed;
    }

    .action-buttons {
        display: flex;
        justify-content: space-between;
        margin-top: 2rem;
        gap: 1rem;
    }

    .btn {
        border-radius: 10px;
        padding: 10px 24px;
        font-weight: 500;
        transition: var(--transition);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-size: 0.95rem;
    }

    .btn-primary {
        background: var(--primary-gradient);
        border: none;
        color: white;
        box-shadow: var(--shadow-sm);
    }

        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: var(--shadow-md);
        }

    .btn-outline {
        border: 2px solid transparent;
        background: var(--bg-color);
        color: var(--text-muted);
        position: relative;
        z-index: 1;
        overflow: hidden;
    }

        .btn-outline::before {
            content: "";
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            border: 2px solid transparent;
            border-radius: 10px;
            background: var(--primary-gradient) border-box;
            -webkit-mask: linear-gradient(#fff 0 0) padding-box, linear-gradient(#fff 0 0);
            -webkit-mask-composite: destination-out;
            mask-composite: exclude;
            z-index: -1;
            transition: var(--transition);
        }



        .btn-outline:hover {
            background: var(--light-gray);
            transform: translateY(-2px);
            box-shadow: var(--shadow-sm);
            color: var(--primary-dark);
        }

    .btn i {
        margin-right: 8px;
        font-size: 0.9em;
    }

    .profile-title {
        text-align: center;
        margin-bottom: 2rem;
        position: relative;
        padding-bottom: 1rem;
        color: var(--text-color);
    }

        .profile-title::after {
            content: "";
            position: absolute;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 80px;
            height: 4px;
            background: var(--primary-gradient);
            border-radius: 2px;
        }

    .text-danger {
        font-size: 0.8rem;
        margin-top: 0.5rem;
        color: #dc3545;
        display: block;
        text-align: left;
    }

    /* Темная тема */
    .dark-theme {
        --bg-color: #121212;
        --card-bg: #121212;
        --text-color: #f8f9fa;
        --light-gray: #343a40;
        --lighter-gray: #495057;
        --border-color: #495057;
        --text-muted: #adb5bd;
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
    }

        .dark-theme body {
            background-color: #121212;
        }

        .dark-theme .profile-field {
            background-color: #2d2d2d;
            color: #f8f9fa;
        }

            .dark-theme .profile-field:hover {
                background-color: #3d3d3d;
            }

            .dark-theme .profile-field:focus {
                background-color: #2d2d2d;
            }

        .dark-theme .profile-field-readonly {
            background-color: #3d3d3d;
        }

        .dark-theme .readonly-section {
            background-color: #2d2d2d;
        }

        .dark-theme .btn-outline {
            background-color: #2d2d2d;
            border-color: #3d3d3d;
            color: #e0e0e0;
        }

            .dark-theme .btn-outline:hover {
                color: var(--primary-light);
            }

    /* Переключатель темы */
    .theme-toggle-container {
        position: absolute;
        top: 20px;
        right: 20px;
    }

    .theme-toggle-btn {
        background: none;
        border: none;
        color: var(--text-muted);
        font-size: 1.2rem;
        cursor: pointer;
    }
</style>

<div class="container py-4">
    <div class="profile-container" id="profileContainer">
        <div class="theme-toggle-container">
            <button class="theme-toggle-btn" id="themeToggle">
                <i class="fas fa-moon"></i>
            </button>
        </div>

        <div class="profile-card">
            <div class="card-body p-4 p-lg-5">
                <h2 class="profile-title">@ViewData["Title"]</h2>

                <form method="post" class="needs-validation" novalidate>
                    <div class="form-group">
                        <label asp-for="UserModel.FirstName" class="form-label">Имя</label>
                        <input asp-for="UserModel.FirstName" class="profile-field" required />
                        <span asp-validation-for="UserModel.FirstName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="UserModel.LastName" class="form-label">Фамилия</label>
                        <input asp-for="UserModel.LastName" class="profile-field" required />
                        <span asp-validation-for="UserModel.LastName" class="text-danger"></span>
                    </div>

                    <div class="form-group">
                        <label asp-for="UserModel.MiddleName" class="form-label">Отчество</label>
                        <input asp-for="UserModel.MiddleName" class="profile-field" />
                        <span asp-validation-for="UserModel.MiddleName" class="text-danger"></span>
                    </div>

                    @if (Model.CurrentRole == "Ученик" && Model.StudentModel != null)
                    {
                        <div class="form-group">
                            <label class="form-label">Группа</label>
                            <input value="@Model.StudentModel.Group?.Name" class="profile-field profile-field-readonly" readonly />
                        </div>
                    }

                    <div class="readonly-section">
                        <div class="readonly-section-title">
                            <i class="fas fa-lock"></i>
                        </div>

                        <div class="form-group">
                            <label class="form-label">Email</label>
                            <input asp-for="UserModel.Email" class="profile-field profile-field-readonly" readonly />
                        </div>

                        <div class="form-group mb-0">
                            <label class="form-label">Роль</label>
                            <input value="@Model.CurrentRole" class="profile-field profile-field-readonly" readonly />
                        </div>
                    </div>

                    <div class="action-buttons">
                        <a asp-page="Profile" class="btn btn-outline">
                            <i class="fas fa-arrow-left"></i> Назад
                        </a>
                        <button type="submit" class="btn btn-primary">
                            <i class="fas fa-save"></i> Сохранить изменения
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const themeToggle = document.getElementById('themeToggle');
            const profileContainer = document.getElementById('profileContainer');

            // Проверяем сохраненную тему
            const savedTheme = localStorage.getItem('theme') || 'light';
            if (savedTheme === 'dark') {
                profileContainer.classList.add('dark-theme');
                themeToggle.innerHTML = '<i class="fas fa-sun"></i>';
            }

            themeToggle.addEventListener('click', function() {
                profileContainer.classList.toggle('dark-theme');
                const isDark = profileContainer.classList.contains('dark-theme');
                localStorage.setItem('theme', isDark ? 'dark' : 'light');
                themeToggle.innerHTML = isDark ? '<i class="fas fa-sun"></i>' : '<i class="fas fa-moon"></i>';
            });
        });
    </script>
}