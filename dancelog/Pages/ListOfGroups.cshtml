@page
@model dancelog.Pages.ListOfGroupsModel
@{
    ViewData["Title"] = "Список групп";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --light-gray: #f8f9fa;
        --lighter-gray: #f0f0f0;
        --border-color: #e0e0e0;
        --shadow-sm: 0 1px 3px rgba(0,0,0,0.12);
        --shadow-md: 0 4px 6px rgba(0,0,0,0.1);
        --shadow-lg: 0 10px 15px rgba(0,0,0,0.1);
        --card-border-radius: 12px;
        --transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
        --card-bg: #ffffff;
        --text-color: #212529;
    }

    body {
        background: linear-gradient(to bottom, #f5f7fa 0%, #e4e8eb 100%);
        min-height: 100vh;
        font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        color: var(--text-color);
    }

        body.dark-theme {
            --text-muted: #a0a0a0;
            --light-gray: #2a2a2a;
            --lighter-gray: #1e1e1e;
            --border-color: #444;
            --card-bg: #121212;
            --text-color: #f1f1f1;
            background: #000000 !important;
        }

    .container {
        max-width: 1400px;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .page-header {
        position: relative;
        padding-bottom: 0.5rem;
        margin-bottom: 1.5rem;
        border-bottom: 1px solid rgba(0,0,0,0.05);
    }

        .page-header h1 {
            font-weight: 600;
            position: relative;
            display: inline-block;
            margin-bottom: 0;
            color: var(--text-color);
        }

            .page-header h1::after {
                content: "";
                position: absolute;
                bottom: -8px;
                left: 0;
                width: 60px;
                height: 4px;
                background: var(--primary-gradient);
                border-radius: 4px;
                transition: width 0.6s ease;
            }

            .page-header h1:hover::after {
                width: 100px;
            }

    .card {
        border: none;
        border-radius: var(--card-border-radius);
        overflow: hidden;
        box-shadow: var(--shadow-sm);
        background: var(--card-bg);
        transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.3s;
        display: flex;
        flex-direction: column;
        height: 100%;
        color: var(--text-color);
    }

        .card:hover {
            transform: translateY(-5px) scale(1.02);
            box-shadow: var(--shadow-lg);
        }

    .card-body {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: 1.5rem;
        text-align: center;
    }

    .card-title {
        font-size: 1.25rem;
        margin-bottom: 0.5rem;
        color: var(--text-color);
    }

    .badge-course {
        margin-bottom: 1rem;
        padding: 0.4rem 0.8rem;
        background: var(--primary-gradient);
        color: #fff;
        border-radius: 0.5rem;
        font-size: 0.85rem;
        font-weight: 500;
    }

    .action-buttons {
        display: flex;
        gap: 0.5rem;
        margin-top: auto;
        margin-top: 1.2rem; /* ← добавлен отступ вниз */
        justify-content: center;
    }

    .btn-group-action {
        transition: transform 0.2s ease, background 0.2s ease;
        color: var(--primary-dark);
        border-color: var(--primary-dark);
    }


        .btn-group-action:hover {
            transform: scale(1.1);
            background: var(--primary-gradient);
            border-color: var(--primary-gradient);
            color: #fff;
        }

    .empty-state .card-body {
        text-align: center;
    }

    /* Темная тема для кнопок */
    body.dark-theme .btn-group-action {
        color: var(--primary-light);
        border-color: var(--primary-light);
    }

        body.dark-theme .btn-group-action:hover {
            background: var(--primary-gradient);
            color: #fff;
            border-color: var(--primary-gradient);
        }

    /* Темная тема для текста */
    body.dark-theme .page-header h1,
    body.dark-theme .card-title {
        color: var(--text-color);
    }

    body.dark-theme .text-muted {
        color: var(--text-muted) !important;
    }

    /* === Градиентная рамка для кнопок редактирования/удаления === */
    .btn-group-action {
        position: relative;
        background: transparent !important;
        color: var(--text-color) !important; /* ваш текст/иконки */
        border: 2px solid transparent !important;
        border-image-source: var(--primary-gradient);
        border-image-slice: 1;
        transition: transform 0.2s ease, background 0.2s ease;
    }

        /* На hover закрашиваем фон градиентом и делаем иконку белой */
        .btn-group-action:hover {
            background: var(--primary-gradient) !important;
            color: #fff !important;
        }

        /* Иконки внутри кнопок */
        .btn-group-action i {
            color: inherit !important; /* подхватят цвет из .btn-group-action */
        }
    /* 1) Сбрасываем все старые бордеры и делаем градиентную обводку */
    .btn-group-action {
        background: transparent !important;
        border: 2px solid transparent !important;
        /* вот ключевое: */
        border-image-source: var(--primary-gradient) !important;
        border-image-slice: 1 !important;
        border-image-repeat: stretch !important;
        border-radius: var(--card-border-radius) !important;
        transition: transform 0.2s ease, background 0.2s ease;
    }

        /* 2) Иконка наследует цвет кнопки */
        .btn-group-action i {
            color: inherit !important;
        }

        /* 3) Hover — просто заливаем градиентом фон, текст и иконка белые */
        .btn-group-action:hover {
            background: var(--primary-gradient) !important;
            color: #fff !important;
        }
</style>

<div class="container py-4">
    @if (Model.Groups != null && Model.Groups.Any())
    {
        <div class="d-flex justify-content-between align-items-center page-header">
            <h1>@ViewData["Title"]</h1>
            <a href="@Url.Page("Group", new { id = 0 })" class="btn btn-create btn-group-action">
                <i class="fas fa-plus me-1"></i> Создать группу
            </a>
        </div>

        <div class="row g-4">
            @foreach (var group in Model.Groups)
            {
                <div class="col-12 col-sm-6 col-md-4 col-lg-3">
                    <div class="card">
                        <div class="card-body">
                            <div class="card-content">
                                <h5 class="card-title">@group.Name</h5>
                                @if (group.Course != null)
                                {
                                    <span class="badge-course">
                                        <i class="fas fa-book-open me-1"></i> @group.Course.Name
                                    </span>
                                }
                            </div>
                            <div class="action-buttons">
                                <a href="@Url.Page("Group", new { id = group.Id })"
                                   class="btn btn-sm btn-outline-secondary btn-group-action" title="Редактировать">
                                    <i class="fas fa-edit"></i>
                                </a>
                                <a href="javascript:void(0);"
                                   onclick="confirmDelete(@group.Id)"
                                   class="btn btn-sm btn-outline-secondary btn-group-action" title="Удалить">
                                    <i class="fas fa-trash-alt"></i>
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="text-center py-5 empty-state">
            <div class="card mx-auto" style="max-width: 400px;">
                <div class="card-body py-5">
                    <h4 class="mt-3">Нет добавленных групп</h4>
                    <p class="text-muted">Нажмите кнопку ниже, чтобы создать группу</p>
                    <a href="@Url.Page("Group", new { id = 0 })"
                       class="btn btn-create btn-group-action mt-3">
                        <i class="fas fa-plus me-1"></i> Создать новую группу
                    </a>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <script>
        function confirmDelete(id) {
            if (confirm('Вы уверены, что хотите удалить эту группу?')) {
                window.location.href = '@Url.Page("GroupDelete")' + '?id=' + id;
            }
        }
    </script>
}