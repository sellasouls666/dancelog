@page
@model dancelog.Pages.GroupModel
@{
    ViewData["Title"] = Model.Group.Id == 0 ? "Добавить группу" : "Редактировать группу";
}

<style>
    :root {
        --primary-gradient: linear-gradient(135deg, #6a11cb 0%, #2575fc 100%);
        --primary-light: #2575fc;
        --primary-dark: #6a11cb;
        --text-muted: #6c757d;
        --light-gray: #f8f9fa;
        --lighter-gray: #f0f0f0;
        --border-color: #e0e0e0;
        --shadow-sm: 0 2px 6px rgba(0,0,0,0.08);
        --shadow-md: 0 4px 12px rgba(0,0,0,0.1);
        --shadow-lg: 0 8px 24px rgba(0,0,0,0.12);
        --card-border-radius: 16px;
        --transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
        --bg-color: #ffffff;
        --card-bg: #ffffff;
        --text-color: #212529;
        --cancel-btn-border: var(--border-color);
        --cancel-btn-text: var(--text-muted);
        --cancel-btn-hover-bg: var(--lighter-gray);
    }

    body {
        background-color: #f5f7fa;
    }

    .container {
        max-width: 800px;
        animation: fadeIn 0.8s ease-out;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .form-card {
        border: none;
        border-radius: var(--card-border-radius);
        overflow: hidden;
        box-shadow: var(--shadow-lg);
        background: var(--card-bg);
        transition: var(--transition);
        color: var(--text-color);
    }

    .card-header {
        background: var(--primary-gradient);
        color: white;
        padding: 1.5rem;
        position: relative;
        overflow: hidden;
    }

        .card-header::after {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: linear-gradient(135deg, rgba(255,255,255,0.1) 0%, rgba(255,255,255,0) 100%);
        }

        .card-header h4 {
            position: relative;
            z-index: 1;
            font-weight: 600;
            margin-bottom: 0;
        }

    .card-body {
        padding: 2rem;
    }

    .form-label {
        font-weight: 500;
        color: var(--text-color);
        margin-bottom: 0.5rem;
    }

    .form-control {
        border-radius: 10px;
        padding: 0.75rem 1rem;
        border: 1px solid var(--border-color);
        transition: var(--transition);
        box-shadow: var(--shadow-sm);
        background-color: var(--bg-color);
        color: var(--text-color);
    }

        .form-control:focus {
            border-color: var(--primary-dark);
            box-shadow: 0 0 0 0.25rem rgba(106, 17, 203, 0.25);
        }

    .text-danger {
        font-size: 0.85rem;
        margin-top: 0.25rem;
        color: #dc3545;
    }

    .btn {
        border-radius: 12px;
        padding: 10px 24px;
        font-weight: 500;
        letter-spacing: 0.5px;
        transition: var(--transition);
        position: relative;
        overflow: hidden;
        z-index: 1;
    }

    .btn-primary {
        background: var(--primary-gradient);
        border: none;
        box-shadow: var(--shadow-sm);
        background-size: 200% 200%;
        color: white;
    }

        .btn-primary:hover {
            transform: translateY(-3px);
            box-shadow: 0 4px 12px rgba(37, 117, 252, 0.3);
        }

        .btn-primary:active {
            transform: translateY(1px);
        }

    .btn-outline-secondary {
        border: 1px solid var(--border-color);
        color: var(--text-muted);
        background-color: transparent;
    }

        .btn-outline-secondary:hover {
            background: var(--lighter-gray);
            color: var(--text-color);
        }

    .cancel-btn {
        border-color: var(--cancel-btn-border) !important;
        color: var(--cancel-btn-text) !important;
    }

        .cancel-btn:hover {
            background-color: var(--cancel-btn-hover-bg) !important;
            color: var(--cancel-btn-text) !important;
        }

    .form-group {
        margin-bottom: 1.5rem;
        animation: slideUp 0.5s ease-out forwards;
        opacity: 0;
    }

    @@keyframes slideUp {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .course-selector {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 0.5rem;
    }

    .course-option {
        flex: 1 0 calc(50% - 10px);
        position: relative;
    }

        .course-option input[type="radio"] {
            position: absolute;
            opacity: 0;
            width: 0;
            height: 0;
        }

        .course-option label {
            display: block;
            padding: 12px 15px;
            border: 2px solid var(--border-color);
            border-radius: 8px;
            background-color: var(--card-bg);
            cursor: pointer;
            transition: var(--transition);
            text-align: center;
            font-weight: 500;
            color: var(--text-color);
        }

            .course-option label:hover {
                border-color: var(--primary-light);
                transform: translateY(-2px);
                box-shadow: var(--shadow-sm);
            }

        .course-option input[type="radio"]:checked + label {
            border-color: var(--primary-dark);
            background: linear-gradient(135deg, rgba(106,17,203,0.1) 0%, rgba(37,117,252,0.1) 100%);
            color: var(--primary-dark);
        }

    .dark-theme {
        --bg-color: #1a1a1a;
        --card-bg: #121212;
        --text-color: #f8f9fa;
        --light-gray: #121212;
        --lighter-gray: #121212;
        --border-color: #495057;
        --primary-gradient: linear-gradient(135deg, #8a2be2 0%, #4b6cb7 100%);
        --primary-light: #4b6cb7;
        --primary-dark: #8a2be2;
        --text-muted: #adb5bd;
        --text-danger: #ff6b6b;
        --cancel-btn-border: white;
        --cancel-btn-text: white;
        --cancel-btn-hover-bg: rgba(255, 255, 255, 0.1);
    }

        .dark-theme .form-control {
            background-color: var(--light-gray);
            color: var(--text-color);
            border-color: var(--border-color);
        }

        .dark-theme .btn-outline-secondary {
            background-color: transparent;
            border-color: var(--border-color);
        }

            .dark-theme .btn-outline-secondary:hover {
                background-color: var(--lighter-gray);
            }

        .dark-theme .course-option label {
            background-color: var(--card-bg);
            border-color: var(--border-color);
        }

        .dark-theme .course-option input[type="radio"]:checked + label {
            border-color: var(--primary-dark);
            background: linear-gradient(135deg, rgba(138,43,226,0.2) 0%, rgba(75,108,183,0.2) 100%);
        }
</style>

<div class="container py-5">
    <div class="form-card">
        <div class="card-header">
            <h4 class="mb-0">@ViewData["Title"]</h4>
        </div>

        <div class="card-body">
            <form method="post">
                <input type="hidden" asp-for="Group.Id" />

                <div class="mb-4 form-group">
                    <label asp-for="Group.Name" class="form-label">Название группы</label>
                    <input asp-for="Group.Name" class="form-control" required />
                    <span asp-validation-for="Group.Name" class="text-danger"></span>
                </div>

                <div class="mb-4 form-group">
                    <label class="form-label">Курс</label>
                    <div class="course-selector">
                        @foreach (var opt in Model.CourseOptions)
                        {
                            <div class="course-option">
                                <input type="radio"
                                       asp-for="Group.CourseId"
                                       id="course_@opt.Value"
                                       value="@opt.Value" />
                                <label for="course_@opt.Value">@opt.Text</label>
                            </div>
                        }
                    </div>
                    <span asp-validation-for="Group.CourseId" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-end mt-4">
                    <a asp-page="ListOfGroups" class="btn btn-outline-secondary cancel-btn me-3">
                        Отмена
                    </a>
                    <button type="submit" class="btn btn-primary">
                        @(Model.Group.Id == 0 ? "Добавить" : "Сохранить")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}